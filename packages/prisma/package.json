{
	"name": "@repo/prisma",
	"version": "1.0.0",
	"description": "Shared Prisma client for the monorepo",
	"type": "module",
	"main": "./index.ts",
	"module": "./index.ts",
	"types": "./index.ts",
	"scripts": {
		"db:generate": "dotenv -e ../../apps/main/.env -- prisma generate --schema=./schema",
		"db:push": "dotenv -e ../../apps/main/.env -- prisma db push --schema=./schema",
		"db:migrate": "dotenv -e ../../apps/main/.env -- prisma migrate dev --schema=./schema",
		"db:studio": "dotenv -e ../../apps/main/.env -- prisma studio --schema=./schema",
		"db:reset": "dotenv -e ../../apps/main/.env -- prisma db push --force-reset --schema=./schema",
		"db:seed": "dotenv -e ../../apps/main/.env -- tsx seed/learnseed.ts",
		"db:seed:practice": "dotenv -e ../../apps/main/.env -- tsx seed/practice-seed.ts",
		"generate": "dotenv -e ../../apps/main/.env -- prisma generate --schema=./schema"
	},
	"prisma": {
		"seed": "tsx seed.ts"
	},
	"exports": {
		".": "./index.ts",
		"./client": "./client.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@prisma/client": "6.14.0",
		"bcryptjs": "^2.4.3"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^22.15.3",
		"dotenv-cli": "^11.0.0",
		"prisma": "6.14.0",
		"tsx": "^4.19.2",
		"typescript": "5.9.2"
	}
}