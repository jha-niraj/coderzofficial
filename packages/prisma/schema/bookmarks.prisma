// ==========================================
// UNIFIED BOOKMARKS SYSTEM
// ==========================================

model ProjectV2Bookmark {
    id String @id @default(cuid())

    projectId String
    project   ProjectV2 @relation("ProjectV2Bookmarks", fields: [projectId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("ProjectV2Bookmarks", fields: [userId], references: [id], onDelete: Cascade)

    folder String? @default("Saved")
    notes  String? @db.Text

    createdAt DateTime @default(now())

    @@unique([projectId, userId])
    @@index([projectId])
    @@index([userId])
    @@index([folder])
}

model CommunityPostBookmark {
    id String @id @default(cuid())

    postId String
    post   CommunityPost @relation("PostBookmarks", fields: [postId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("CommunityPostBookmarks", fields: [userId], references: [id], onDelete: Cascade)

    folder String? @default("Saved")
    notes  String? @db.Text

    createdAt DateTime @default(now())

    @@unique([postId, userId])
    @@index([postId])
    @@index([userId])
    @@index([folder])
}

model MockInterviewBookmark {
    id String @id @default(cuid())

    sessionId String
    session   MockVoiceSession @relation("MockInterviewBookmarks", fields: [sessionId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("MockInterviewBookmarks", fields: [userId], references: [id], onDelete: Cascade)

    folder String? @default("Saved")
    notes  String? @db.Text

    createdAt          DateTime @default(now())
    mockVoiceSessionId String?

    @@unique([sessionId, userId])
    @@index([sessionId])
    @@index([userId])
    @@index([folder])
}