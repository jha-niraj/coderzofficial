// ===============================================
// COMMUNITY PLATFORM MODELS
// ===============================================

enum CommunityType {
    OFFICIAL // Platform-owned channels (General, Showcase, Help)
    USER_CREATED // User-created communities
    ORGANIZATION // Verified organizations (colleges, companies)
}

enum CommunityVisibility {
    PUBLIC // Anyone can see and join
    PRIVATE // Invite only, hidden from search
    RESTRICTED // Visible but requires approval to join
}

enum CommunityRole {
    OWNER
    ADMIN
    MODERATOR
    MEMBER
}

enum CommunityPostType {
    DISCUSSION
    QUESTION
    RESOURCE
    SHOWCASE
    EVENT
    POLL
    CHALLENGE
    HELP_REQUEST
    ANNOUNCEMENT
}

enum CommunityResourceType {
    PDF
    VIDEO
    LINK
    CODE
    IMAGE
    OTHER
}

enum CommunityEventStatus {
    UPCOMING
    ONGOING
    COMPLETED
    CANCELLED
}

enum AttendeeStatus {
    GOING
    INTERESTED
    NOT_GOING
}

// Main Community Model
model Community {
    id               String  @id @default(cuid())
    name             String
    slug             String  @unique
    description      String  @db.Text
    shortDescription String? @db.VarChar(200)
    coverImage       String?
    logo             String?
    themeColor       String  @default("#3B82F6")

    // Type and visibility
    type       CommunityType       @default(USER_CREATED)
    visibility CommunityVisibility @default(PUBLIC)
    category   String              @default("General") // Tech, Study, Career, etc.

    // Verification
    isVerified         Boolean   @default(false)
    verifiedAt         DateTime?
    verificationReason String?   @db.Text

    // Settings (configurable sections)
    enabledSections String[] // ["FEED", "RESOURCES", "QA", "SHOWCASE", etc.]
    rules           String[]
    tags            String[]
    settings        Json? // Additional settings JSON

    // Join questions (for restricted communities)
    joinQuestions String[]

    // Social Links
    websiteUrl   String?
    contactEmail String?
    twitterUrl   String?
    instagramUrl String?
    discordUrl   String?
    githubUrl    String?
    linkedinUrl  String?
    youtubeUrl   String?

    // Counts (denormalized for performance)
    memberCount Int @default(0)
    postCount   Int @default(0)

    // Featured/Promoted
    isFeatured Boolean   @default(false)
    featuredAt DateTime?

    // Creator relation
    creatorId String
    creator   User   @relation("CommunityCreator", fields: [creatorId], references: [id])

    // Relations
    members     CommunityMember[]       @relation("CommunityMembers")
    posts       CommunityPost[]         @relation("CommunityPosts")
    resources   CommunityResource[]     @relation("CommunityResources")
    events      CommunityEvent[]        @relation("CommunityEvents")
    challenges  CommunityChallengeNew[] @relation("CommunityChallenges")
    invites     CommunityInvite[]       @relation("CommunityInvites")
    leaderboard CommunityLeaderboard[]  @relation("CommunityLeaderboard")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([slug])
    @@index([type])
    @@index([visibility])
    @@index([category])
    @@index([creatorId])
    @@index([isFeatured])
    @@index([memberCount])
}

// Community Membership
model CommunityMember {
    id String @id @default(cuid())

    communityId String
    community   Community @relation("CommunityMembers", fields: [communityId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("CommunityMemberships", fields: [userId], references: [id], onDelete: Cascade)

    role     CommunityRole @default(MEMBER)
    joinedAt DateTime      @default(now())

    // Notification preferences
    notifyPosts    Boolean @default(true)
    notifyMentions Boolean @default(true)
    notifyEvents   Boolean @default(true)

    // Stats
    postCount    Int @default(0)
    helpfulCount Int @default(0)

    // For restricted communities
    isApproved  Boolean   @default(true)
    approvedAt  DateTime?
    approvedBy  String?
    joinAnswers Json? // Answers to join questions (for restricted communities)

    @@unique([communityId, userId])
    @@index([communityId])
    @@index([userId])
    @@index([role])
}

// Community Posts
model CommunityPost {
    id String @id @default(cuid())

    communityId String?
    community   Community? @relation("CommunityPosts", fields: [communityId], references: [id], onDelete: Cascade)

    authorId String
    author   User   @relation("CommunityPostAuthor", fields: [authorId], references: [id])

    // Content
    title   String?
    content String            @db.Text
    type    CommunityPostType @default(DISCUSSION)

    // Rich content (JSON for flexibility)
    attachments Json? // Images, files, links
    embeds      Json? // Project embeds, code blocks
    codeBlocks  Json? // Syntax-highlighted code

    // Metadata
    isPinned Boolean   @default(false)
    isLocked Boolean   @default(false)
    isEdited Boolean   @default(false)
    editedAt DateTime?

    // For Q&A type posts
    isAnswered       Boolean @default(false)
    acceptedAnswerId String?

    // For Help Request type
    isResolved Boolean   @default(false)
    resolvedAt DateTime?

    // Tags for filtering
    tags String[]

    // Counts (denormalized)
    likeCount    Int @default(0)
    commentCount Int @default(0)
    viewCount    Int @default(0)
    shareCount   Int @default(0)

    // Platform integrations
    linkedProjectId String? // Link to a ProjectV2
    linkedMockId    String? // Link to a mock interview
    linkedLearnId   String? // Link to a Learn

    // Official channel for global posts (general, showcase, help, career, wins)
    officialChannel String?

    // Slug for SEO-friendly URLs
    slug String? @unique

    // Relations
    likes     CommunityPostLike[]     @relation("PostLikes")
    comments  CommunityComment[]      @relation("PostComments")
    bookmarks CommunityPostBookmark[] @relation("PostBookmarks")
    poll      CommunityPoll?          @relation("PostPoll")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([communityId])
    @@index([authorId])
    @@index([type])
    @@index([isPinned])
    @@index([createdAt])
    @@index([likeCount])
}

// Post Likes
model CommunityPostLike {
    id        String        @id @default(cuid())
    postId    String
    post      CommunityPost @relation("PostLikes", fields: [postId], references: [id], onDelete: Cascade)
    userId    String
    user      User          @relation("CommunityPostLikes", fields: [userId], references: [id], onDelete: Cascade)
    createdAt DateTime      @default(now())

    @@unique([postId, userId])
    @@index([postId])
    @@index([userId])
}

// Comments on Posts
model CommunityComment {
    id String @id @default(cuid())

    postId String
    post   CommunityPost @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)

    authorId String
    author   User   @relation("CommunityCommentAuthor", fields: [authorId], references: [id])

    content String @db.Text

    // For nested replies
    parentId String?
    parent   CommunityComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
    replies  CommunityComment[] @relation("CommentReplies")

    // For accepted answers in Q&A
    isAccepted Boolean @default(false)

    // Edit tracking
    isEdited Boolean   @default(false)
    editedAt DateTime?

    likeCount Int                    @default(0)
    likes     CommunityCommentLike[] @relation("CommentLikes")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([postId])
    @@index([authorId])
    @@index([parentId])
}

// Comment Likes
model CommunityCommentLike {
    id        String           @id @default(cuid())
    commentId String
    comment   CommunityComment @relation("CommentLikes", fields: [commentId], references: [id], onDelete: Cascade)
    userId    String
    user      User             @relation("CommunityCommentLikes", fields: [userId], references: [id], onDelete: Cascade)
    createdAt DateTime         @default(now())

    @@unique([commentId, userId])
    @@index([commentId])
    @@index([userId])
}

// Community Resources (files, PDFs, links)
model CommunityResource {
    id String @id @default(cuid())

    communityId String
    community   Community @relation("CommunityResources", fields: [communityId], references: [id], onDelete: Cascade)

    uploaderId String
    uploader   User   @relation("CommunityResourceUploader", fields: [uploaderId], references: [id])

    title        String
    description  String?               @db.Text
    type         CommunityResourceType
    url          String // File URL or external link
    thumbnailUrl String?
    fileSize     Int? // In bytes
    mimeType     String?

    // Organization
    folder String? // Folder name for organization
    tags   String[]

    downloadCount Int @default(0)
    viewCount     Int @default(0)

    isPinned Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([communityId])
    @@index([uploaderId])
    @@index([type])
    @@index([folder])
}

// Community Events
model CommunityEvent {
    id String @id @default(cuid())

    communityId String
    community   Community @relation("CommunityEvents", fields: [communityId], references: [id], onDelete: Cascade)

    creatorId String
    creator   User   @relation("CommunityEventCreator", fields: [creatorId], references: [id])

    title       String
    description String  @db.Text
    coverImage  String?

    // Schedule
    startDate DateTime
    endDate   DateTime?
    timezone  String    @default("UTC")
    isAllDay  Boolean   @default(false)

    // Location
    locationType String  @default("online") // online, in-person, hybrid
    location     String? // Physical address or platform name
    meetingLink  String? // Virtual meeting URL

    // Capacity
    maxAttendees     Int?
    currentAttendees Int  @default(0)

    // Status
    status CommunityEventStatus @default(UPCOMING)

    // Recurring
    isRecurring    Boolean @default(false)
    recurrenceRule String? // RRULE format

    // Relations
    attendees CommunityEventAttendee[] @relation("EventAttendees")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([communityId])
    @@index([creatorId])
    @@index([startDate])
    @@index([status])
}

// Event Attendees
model CommunityEventAttendee {
    id        String         @id @default(cuid())
    eventId   String
    event     CommunityEvent @relation("EventAttendees", fields: [eventId], references: [id], onDelete: Cascade)
    userId    String
    user      User           @relation("CommunityEventAttendees", fields: [userId], references: [id], onDelete: Cascade)
    status    AttendeeStatus @default(GOING)
    createdAt DateTime       @default(now())

    @@unique([eventId, userId])
    @@index([eventId])
    @@index([userId])
}

// Community Challenges (renamed to avoid conflict with existing)
model CommunityChallengeNew {
    id String @id @default(cuid())

    communityId String
    community   Community @relation("CommunityChallenges", fields: [communityId], references: [id], onDelete: Cascade)

    creatorId String
    creator   User   @relation("CommunityChallengeCreator", fields: [creatorId], references: [id])

    title       String
    description String  @db.Text
    rules       String? @db.Text

    // Schedule
    startDate DateTime
    endDate   DateTime

    // Prizes
    prizeCredits     Int?
    prizeBadge       String?
    prizeDescription String? @db.Text

    // Submissions
    maxSubmissions  Int? // Max per user
    submissionCount Int  @default(0)

    isActive Boolean @default(true)

    submissions CommunityChallengeSubmission[] @relation("ChallengeSubmissions")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([communityId])
    @@index([creatorId])
    @@index([endDate])
    @@index([isActive])
}

// Challenge Submissions
model CommunityChallengeSubmission {
    id          String                @id @default(cuid())
    challengeId String
    challenge   CommunityChallengeNew @relation("ChallengeSubmissions", fields: [challengeId], references: [id], onDelete: Cascade)
    userId      String
    user        User                  @relation("CommunityChallengeSubmissions", fields: [userId], references: [id])

    content     String @db.Text
    attachments Json?

    score    Int?
    rank     Int?
    feedback String? @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([challengeId, userId])
    @@index([challengeId])
    @@index([userId])
}

// Community Invites
model CommunityInvite {
    id String @id @default(cuid())

    communityId String
    community   Community @relation("CommunityInvites", fields: [communityId], references: [id], onDelete: Cascade)

    inviterId String
    inviter   User   @relation("CommunityInviter", fields: [inviterId], references: [id])

    inviteeId    String? // If inviting existing user
    inviteeEmail String? // If inviting by email

    code      String    @unique @default(cuid())
    isUsed    Boolean   @default(false)
    usedAt    DateTime?
    expiresAt DateTime?

    createdAt DateTime @default(now())

    @@index([communityId])
    @@index([inviterId])
    @@index([code])
}

// User Follow System
model UserFollow {
    id          String   @id @default(cuid())
    followerId  String
    follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
    followingId String
    following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
    createdAt   DateTime @default(now())

    @@unique([followerId, followingId])
    @@index([followerId])
    @@index([followingId])
}

// Community Tags (global tags for discovery)
model CommunityTag {
    id         String  @id @default(cuid())
    name       String
    slug       String  @unique
    color      String?
    usageCount Int     @default(0)

    createdAt DateTime @default(now())

    @@index([slug])
    @@index([usageCount])
}

// Community Leaderboard - tracks member points for activities
model CommunityLeaderboard {
    id String @id @default(cuid())

    communityId String
    community   Community @relation("CommunityLeaderboard", fields: [communityId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("CommunityLeaderboards", fields: [userId], references: [id], onDelete: Cascade)

    // Points breakdown
    totalPoints    Int @default(0)
    postPoints     Int @default(0)
    commentPoints  Int @default(0)
    quizPoints     Int @default(0)
    peerMockPoints Int @default(0)
    helpPoints     Int @default(0)

    // Activity counts
    postsCount         Int @default(0)
    commentsCount      Int @default(0)
    quizzesCompleted   Int @default(0)
    questionsCorrect   Int @default(0)
    peerSessionsCount  Int @default(0)
    helpRequestsSolved Int @default(0)

    // Ranking (calculated)
    rank Int?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([communityId, userId])
    @@index([communityId])
    @@index([userId])
    @@index([totalPoints])
    @@index([rank])
}

// Community Polls
model CommunityPoll {
    id String @id @default(cuid())

    postId String        @unique
    post   CommunityPost @relation("PostPoll", fields: [postId], references: [id], onDelete: Cascade)

    question      String
    options       Json // Array of strings
    allowMultiple Boolean   @default(false)
    endDate       DateTime?

    votes CommunityPollVote[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([postId])
}

model CommunityPollVote {
    id String @id @default(cuid())

    pollId String
    poll   CommunityPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("CommunityPollVotes", fields: [userId], references: [id], onDelete: Cascade)

    optionIndex Int // Index of the option selected

    createdAt DateTime @default(now())
    // If allowMultiple is true, a user can select multiple options.
    // So unique constraint should be [pollId, userId, optionIndex] to prevent duplicate votes for same option.

    @@unique([pollId, userId, optionIndex]) // userId per poll? No, user can vote multiple times if allowMultiple?
    @@index([pollId])
    @@index([userId])
}