// ================================================================================
// ACHIEVEMENTS & GAMIFICATION SYSTEM
// Comprehensive badge, level, and social sharing system
// ================================================================================

// ================================================================================
// ENUMS
// ================================================================================

enum BadgeCategory {
    // Module-based categories
    PROJECTS // Project completions
    ASSESSMENTS // Exams, practice, certifications
    CHALLENGES // Forge, Crucible
    MOCK_INTERVIEWS // Mock interview completions
    COMMUNITY // Community participation
    LEARN           @map("CONCEPTS") // Learning Learns
    SPACES // Space completions
    STUDIO // Studio creations
    OPENSOURCE // Open source contributions
    PATHFINDER // Learning goals
    LAUNCHPADS // Product submissions
    COLLECTIVE // Collective participation
    PORTFOLIO // Portfolio achievements

    // General categories
    CONSISTENCY // Streaks, daily activity
    SOCIAL // Followers, likes, engagement
    MILESTONE // XP milestones, level ups
    SPECIAL // Special events, limited edition
}

enum BadgeRarity {
    COMMON // Easy to earn, basic milestones
    RARE // Moderate difficulty
    EPIC // Challenging achievements
    LEGENDARY // Very difficult, exceptional
    MYTHIC // Ultra rare, special achievements
}

enum AchievementStatus {
    LOCKED // Not yet available
    IN_PROGRESS // User has started progress
    READY_TO_CLAIM // Completed but not claimed
    CLAIMED // User has claimed the badge
}

enum SocialProvider {
    TWITTER
    LINKEDIN
}

// ================================================================================
// BADGE DEFINITIONS (Seeded from database)
// ================================================================================

model Badge {
    id String @id @default(cuid())

    // Identification
    slug        String @unique // Unique identifier for code reference
    name        String // Display name
    description String @db.Text // What the badge is for

    // Visual
    icon       String // Icon identifier or URL
    color      String // Primary color hex
    bgGradient String? // Background gradient CSS

    // Classification
    category BadgeCategory
    rarity   BadgeRarity   @default(COMMON)

    // Requirements (JSON structure for flexibility)
    // e.g., { "type": "count", "target": "projects_completed", "count": 5 }
    // e.g., { "type": "score", "target": "quiz_score", "min": 95 }
    requirements Json

    // Rewards
    xpReward      Int @default(0) // XP awarded on claim
    creditsReward Int @default(0) // Credits awarded on claim

    // Ordering and grouping
    order Int @default(0) // Display order within category
    tier  Int @default(1) // Tier level (1, 2, 3 for bronze, silver, gold)

    // Status
    isActive  Boolean   @default(true)
    isLimited Boolean   @default(false) // Limited time badge
    expiresAt DateTime? // For limited badges

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    userBadges UserBadge[]

    @@index([category])
    @@index([rarity])
    @@index([isActive])
}

// ================================================================================
// USER BADGE TRACKING
// ================================================================================

model UserBadge {
    id String @id @default(cuid())

    // Relations
    userId  String
    user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    badgeId String
    badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

    // Status
    status AchievementStatus @default(LOCKED)

    // Progress tracking (JSON for flexible progress data)
    // e.g., { "current": 3, "target": 5, "items": ["proj1", "proj2", "proj3"] }
    progress        Json?
    progressPercent Int   @default(0)

    // Timestamps
    unlockedAt  DateTime? // When progress started
    completedAt DateTime? // When requirements met
    claimedAt   DateTime? // When user claimed the badge

    // Sharing
    sharedToTwitter  Boolean @default(false)
    sharedToLinkedIn Boolean @default(false)
    shareCount       Int     @default(0)

    // Display preferences
    isPinned     Boolean @default(false) // Show on profile
    displayOrder Int     @default(0) // Order on profile

    @@unique([userId, badgeId])
    @@index([userId])
    @@index([badgeId])
    @@index([status])
    @@index([claimedAt])
}

// ================================================================================
// LEVEL SYSTEM (Enhanced)
// ================================================================================

model Level {
    id    Int @id @default(autoincrement())
    level Int @unique

    // Display
    title       String // e.g., "Code Novice", "Algorithm Master"
    description String? @db.Text
    icon        String? // Level icon
    color       String? // Level color theme

    // Requirements
    xpRequired Int // Total XP required to reach this level

    // Rewards
    xpReward      Int @default(0) // Bonus XP on level up
    creditsReward Int @default(0) // Credits on level up

    // Perks (JSON for flexible perks)
    // e.g., { "dailyBonus": 1.1, "unlocks": ["feature1"] }
    perks Json?

    // Status
    isActive Boolean @default(true)

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    userProgress UserLevelProgress[]

    @@index([level])
}

model UserLevelProgress {
    id String @id @default(cuid())

    // Relations
    userId    String
    user      User   @relation("UserLevelProgress", fields: [userId], references: [id], onDelete: Cascade)
    level     Int
    levelInfo Level  @relation(fields: [level], references: [level], onDelete: Cascade)

    // Tracking
    xpEarned      Int      @default(0) // XP earned at this level
    creditsEarned Int      @default(0) // Credits earned at this level
    achievedAt    DateTime @default(now())

    // Sharing
    sharedToSocial Boolean @default(false)

    @@unique([userId, level])
    @@index([userId])
    @@index([level])
}

// ================================================================================
// XP TRANSACTIONS
// ================================================================================

model XpTransaction {
    id String @id @default(uuid())

    // Relations
    userId String
    user   User   @relation(fields: [userId], references: [id])

    // Transaction details
    amount      Int
    description String
    type        XpTransactionProps @default(REWARD)

    // Source tracking
    source   String? // Module that generated this XP
    sourceId String? // Related entity ID

    // Timestamps
    createdAt DateTime @default(now())

    @@index([userId])
    @@index([createdAt])
    @@index([type])
}

// ================================================================================
// SOCIAL CONNECTIONS
// ================================================================================

model SocialConnection {
    id String @id @default(cuid())

    // User relation
    userId String
    user   User   @relation("UserSocialConnections", fields: [userId], references: [id], onDelete: Cascade)

    // Provider details
    provider          SocialProvider
    providerAccountId String // External account ID

    // OAuth tokens (encrypted)
    accessToken    String    @db.Text
    refreshToken   String?   @db.Text
    tokenExpiresAt DateTime?

    // Account info
    accountName   String? // Display name on platform
    accountHandle String? // @handle or username
    accountImage  String? // Profile image URL

    // Status
    isActive   Boolean   @default(true)
    lastUsedAt DateTime?

    // Timestamps
    connectedAt DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@unique([userId, provider])
    @@index([userId])
    @@index([provider])
}

// ================================================================================
// SOCIAL SHARES HISTORY
// ================================================================================

model SocialShare {
    id String @id @default(cuid())

    // User relation
    userId String
    user   User   @relation("UserSocialShares", fields: [userId], references: [id], onDelete: Cascade)

    // Share details
    provider    SocialProvider
    shareType   String // "badge", "level_up", "achievement", "project"
    referenceId String? // ID of the thing being shared

    // Content
    content String @db.Text // The actual post content

    // External reference
    externalPostId String? // Post ID on the platform
    externalUrl    String? // URL to the post

    // Status
    wasSuccessful Boolean @default(true)
    errorMessage  String?

    // Timestamps
    sharedAt DateTime @default(now())

    @@index([userId])
    @@index([provider])
    @@index([shareType])
    @@index([sharedAt])
}

// ================================================================================
// ACHIEVEMENT NOTIFICATIONS
// ================================================================================

model AchievementNotification {
    id String @id @default(cuid())

    // User relation
    userId String
    user   User   @relation("UserAchievementNotifications", fields: [userId], references: [id], onDelete: Cascade)

    // Notification details
    type    String // "badge_unlocked", "badge_ready", "level_up", "milestone"
    title   String
    message String @db.Text

    // Reference
    referenceType String? // "badge", "level", etc.
    referenceId   String?

    // Visual
    icon  String?
    color String?

    // Status
    isRead      Boolean @default(false)
    isDismissed Boolean @default(false)

    // Timestamps
    createdAt DateTime  @default(now())
    readAt    DateTime?

    @@index([userId])
    @@index([isRead])
    @@index([createdAt])
}

// ================================================================================
// USER ACHIEVEMENT STATS (Cached stats for quick access)
// ================================================================================

model UserAchievementStats {
    id String @id @default(cuid())

    // User relation
    userId String @unique
    user   User   @relation("UserAchievementStats", fields: [userId], references: [id], onDelete: Cascade)

    // Badge counts by rarity
    commonBadges    Int @default(0)
    rareBadges      Int @default(0)
    epicBadges      Int @default(0)
    legendaryBadges Int @default(0)
    mythicBadges    Int @default(0)
    totalBadges     Int @default(0)

    // Progress
    badgesInProgress   Int @default(0)
    badgesReadyToClaim Int @default(0)

    // XP & Credits from achievements
    totalXpFromBadges      Int @default(0)
    totalCreditsFromBadges Int @default(0)

    // Sharing stats
    totalShares Int @default(0)

    // Timestamps
    updatedAt DateTime @updatedAt

    @@index([userId])
}
