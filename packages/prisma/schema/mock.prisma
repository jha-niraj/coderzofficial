// ============================================
// MOCK INTERVIEW VOICE (ElevenLabs)
// ============================================

model MockInterviewVoice {
    id String @id @default(cuid())

    // Basic Info
    title       String
    description String       @db.Text
    category    MockCategory @default(TECHNICAL)
    level       MockLevel    @default(INTERMEDIATE)

    // Configuration
    duration       Int     @default(15) // in minutes
    questionsCount Int     @default(5) // number of questions
    isPublic       Boolean @default(true)
    isPredefined   Boolean @default(false) // true for platform-created, false for user-created
    byAdmin        Boolean @default(false) // true for admin-seeded mocks (shows badge)

    // Knowledge Base
    knowledgeBase String @db.Text // The AI interviewer instructions and context

    // Creator Info (null for predefined mocks)
    createdById String?
    createdBy   User?   @relation("MockVoiceCreator", fields: [createdById], references: [id], onDelete: Cascade)

    // Resume Integration (for user-created mocks)
    includesResume Boolean @default(false)

    // Featured flag for homepage display
    isFeatured Boolean @default(false)

    // Pricing
    baseCredits     Int @default(15)
    creditsRequired Int @default(15) // Final calculated credits

    // Metadata
    tags          String[]
    popularity    Int      @default(0) // Incremented with each session
    totalSessions Int      @default(0)
    averageRating Float?

    // Predefined Mock Reference (for linking to data file)
    predefinedId String? @unique // matches ID from predefined-mocks.ts

    // University Integration - for teacher-assigned mock interviews
    isUniversityMock Boolean @default(false) // If created by a university teacher
    universityId     String? // Link to University model
    teacherMemberId  String? // Link to UniversityMember (teacher who created)
    classIds         String[] // Array of class IDs this mock is assigned to
    
    // University Assignment Config
    assignmentDeadline    DateTime? // Optional deadline for university assignments
    assignmentCredits     Int?      // Credits required for this assignment
    assignmentInstructions String?  @db.Text // Additional instructions from teacher

    // Relations
    sessions MockVoiceSession[]
    ratings  MockVoiceRating[]

    // Pathfinder (Learning Goals) back-relation
    pathfinderGoal       PathfinderGoal?    @relation("PathfinderMockInterview")
    
    pathfinderSubGoalId  String?    @unique // Link to subgoal for practice mock
    pathfinderSubGoal    PathfinderSubGoal? @relation("PathfinderSubGoalMock", fields: [pathfinderSubGoalId], references: [id], onDelete: SetNull)

    // Concept Step back-relation (for MOCK_INTERVIEW step type)
    conceptStep ConceptStep? @relation("ConceptStepMockInterview")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([category])
    @@index([level])
    @@index([isPublic])
    @@index([isPredefined])
    @@index([createdById])
    @@index([popularity])
    @@index([universityId])
    @@index([isUniversityMock])
}

model MockVoiceSession {
    id String @id @default(cuid())

    // Relations
    mockId String
    mock   MockInterviewVoice @relation(fields: [mockId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("MockVoiceSessions", fields: [userId], references: [id], onDelete: Cascade)

    // Session Details
    status String @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED

    // ElevenLabs Integration
    conversationId String? @unique // ElevenLabs conversation ID
    agentId        String? // ElevenLabs agent ID (from env)

    // Dynamic Variables Passed to ElevenLabs
    variables Json // { position, description, level, knowledge_base, resume_content? }

    // Session Timing
    scheduledFor DateTime?
    startedAt    DateTime?
    completedAt  DateTime?
    duration     Int? // actual duration in seconds

    // Audio & Transcript
    recordingUrl  String?
    transcriptUrl String?
    transcript    String? @db.Text

    // AI Analysis
    aiAnalysis Json? // Detailed analysis from ElevenLabs/GPT

    // User Feedback & Review
    userRating   Int? // 1-5 stars
    userFeedback String?   @db.Text
    reviewedAt   DateTime?

    // Issue Reporting (for problematic sessions)
    hasIssues       Boolean   @default(false)
    reportedIssues  String[] // Array of issue types: "AUDIO_QUALITY", "AI_RESPONSES", "TECHNICAL_ERROR", "INAPPROPRIATE", "OTHER"
    issueDetails    String?   @db.Text
    issueReportedAt DateTime?

    // Credits
    creditsUsed Int

    // Metadata
    metadata Json? // Additional session data

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    mockInterviewBookmarks MockInterviewBookmark[] @relation("MockInterviewBookmarks")

    @@index([mockId])
    @@index([userId])
    @@index([status])
    @@index([conversationId])
    @@index([scheduledFor])
}

model MockVoiceRating {
    id String @id @default(cuid())

    mockId String
    mock   MockInterviewVoice @relation(fields: [mockId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("MockVoiceRatings", fields: [userId], references: [id], onDelete: Cascade)

    rating Int // 1-5
    review String? @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([mockId, userId])
    @@index([mockId])
    @@index([userId])
}