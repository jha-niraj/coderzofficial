// ============================================
// STUDIO (Learning Workspace) MODELS
// ============================================

enum StudioCategory {
    GENERAL
    PROGRAMMING
    WEB_DEVELOPMENT
    DATA_SCIENCE
    DEVOPS
    MOBILE_DEVELOPMENT
    SYSTEM_DESIGN
    INTERVIEW_PREP
    PROJECT_NOTES
    TUTORIAL
    COURSE_NOTES
    OTHER
}

enum StudioBlockType {
    TEXT
    HEADING
    CODE
    QUIZ
    FLASHCARD
    IMAGE
    VIDEO
    PRACTICE
    MOCK_INTERVIEW
    EMBED
    DIVIDER
    CALLOUT
    BULLET_LIST
    NUMBERED_LIST
}

enum StudioVisibility {
    PRIVATE
    PUBLIC
    COMMUNITY
}

enum StudioMediaType {
    IMAGE
    VIDEO
    DIAGRAM
    UPLOAD
}

model Studio {
    id          String  @id @default(cuid())
    slug        String? @unique
    title       String
    description String? @db.Text
    emoji       String? @default("📚")
    coverImage  String?

    // Content stored as JSON (block-based)
    content Json @default("[]")

    // Metadata
    category   StudioCategory   @default(GENERAL)
    tags       String[]
    visibility StudioVisibility @default(PRIVATE)
    isTemplate Boolean          @default(false)

    // Stats
    views  Int @default(0)
    clones Int @default(0)
    likes  Int @default(0)

    // Relationships
    userId String
    user   User   @relation("UserStudios", fields: [userId], references: [id], onDelete: Cascade)

    // Project linking
    projectId String?

    // Embedded content
    quizzes        StudioQuiz[]
    flashcardDecks StudioFlashcardDeck[]
    codeBlocks     StudioCodeBlock[]
    mediaBlocks    StudioMediaBlock[]

    // AI Chat history
    chatHistory StudioChatMessage[]

    // Space relation
    spaceId String?
    space   Space?  @relation("SpaceStudios", fields: [spaceId], references: [id], onDelete: SetNull)

    // Timestamps
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
    lastEditedAt DateTime @default(now())

    // Pathfinder (Learning Goals) back-relation
    pathfinderGoal PathfinderGoal? @relation("PathfinderStudio")

    @@index([userId])
    @@index([category])
    @@index([visibility])
    @@index([spaceId])
}

model StudioQuiz {
    id      String @id @default(cuid())
    blockId String // Reference to block in content JSON

    title     String
    questions Json // Array of QuizQuestion objects

    // Settings
    timeLimit          Int? // In seconds
    shuffleQuestions   Boolean @default(true)
    showCorrectAnswers Boolean @default(true)

    studioId String
    studio   Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

    // Attempts
    attempts StudioQuizAttempt[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([studioId])
    @@index([blockId])
}

model StudioQuizAttempt {
    id String @id @default(cuid())

    quizId String
    quiz   StudioQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("UserStudioQuizAttempts", fields: [userId], references: [id], onDelete: Cascade)

    score     Int
    maxScore  Int
    answers   Json // User's answers
    timeTaken Int? // In seconds

    createdAt DateTime @default(now())

    @@index([quizId])
    @@index([userId])
}

model StudioFlashcardDeck {
    id      String @id @default(cuid())
    blockId String // Reference to block in content JSON

    title String
    cards Json // Array of {front, back, hint?}

    studioId String
    studio   Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

    // Study progress
    studySessions StudioFlashcardSession[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([studioId])
    @@index([blockId])
}

model StudioFlashcardSession {
    id String @id @default(cuid())

    deckId String
    deck   StudioFlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("UserFlashcardSessions", fields: [userId], references: [id], onDelete: Cascade)

    cardsStudied Int
    correctCount Int
    studyTime    Int // In seconds
    cardProgress Json // {cardIndex: {correct, incorrect, lastSeen}}

    createdAt DateTime @default(now())

    @@index([deckId])
    @@index([userId])
}

model StudioCodeBlock {
    id      String @id @default(cuid())
    blockId String // Reference to block in content JSON

    language String
    code     String @db.Text

    // For practice problems
    isPractice         Boolean  @default(false)
    problemTitle       String?
    problemDescription String?  @db.Text
    testCases          Json? // Array of {input, expectedOutput}
    hints              String[]
    solution           String?  @db.Text

    studioId String
    studio   Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([studioId])
    @@index([blockId])
}

model StudioMediaBlock {
    id      String @id @default(cuid())
    blockId String // Reference to block in content JSON

    type   StudioMediaType
    url    String
    prompt String?         @db.Text // AI generation prompt

    // Metadata
    width    Int?
    height   Int?
    duration Int? // For videos, in seconds

    studioId String
    studio   Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@index([studioId])
    @@index([blockId])
}

model StudioChatMessage {
    id String @id @default(cuid())

    studioId String
    studio   Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

    role    String // 'user' or 'assistant'
    content String @db.Text

    createdAt DateTime @default(now())

    @@index([studioId])
}