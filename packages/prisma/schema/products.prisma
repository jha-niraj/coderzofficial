// Product Ideas Submission
model ProductIdea {
    id String @id @default(cuid())

    // Basic Info
    title           String
    description     String  @db.Text
    helpDescription String  @db.Text // How it helps students
    category        String  @default("Learning Tool")
    link            String? // Optional demo/mockup link

    // Submission Info
    submittedById String
    submittedBy   User   @relation("ProductIdeas", fields: [submittedById], references: [id], onDelete: Cascade)

    // Status
    status     String  @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, REJECTED, IMPLEMENTED
    adminNotes String? @db.Text

    // Engagement
    upvotes Int @default(0)
    views   Int @default(0)

    // Timestamps
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt
    reviewedAt DateTime?

    @@index([submittedById])
    @@index([status])
    @@index([category])
    @@index([createdAt])
}