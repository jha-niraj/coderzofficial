// ===============================================
// PROJECTS V2 - MAIN PROJECT MODEL AND RELATED ENTITIES
// ===============================================

// ===============================================
// PROJECT CATEGORIES & TECHNOLOGIES (DB-driven)
// ===============================================
model ProjectCategory {
    id          String  @id @default(cuid())
    slug        String  @unique // e.g., "web-development"
    name        String // e.g., "Web Development"
    description String  @db.Text
    icon        String // Lucide icon name e.g., "Globe"
    color       String // Gradient class e.g., "from-blue-500 to-cyan-500"
    orderIndex  Int     @default(0)
    isActive    Boolean @default(true)

    technologies ProjectTechnology[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([slug])
    @@index([orderIndex])
    @@index([isActive])
}

model ProjectTechnology {
    id               String   @id @default(cuid())
    slug             String   @unique // e.g., "react"
    name             String // e.g., "React"
    description      String
    icon             String // Emoji or icon string e.g., "⚛️"
    color            String // Gradient e.g., "from-indigo-400 to-indigo-600"
    learningOutcomes String[] // What you'll learn
    projectCount     Int      @default(0) // Cached count of seeded projects
    orderIndex       Int      @default(0)
    isActive         Boolean  @default(true)

    categoryId String
    category   ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([categoryId])
    @@index([slug])
    @@index([orderIndex])
    @@index([isActive])
}

enum ProjectV2Visibility {
    PRIVATE
    PUBLIC
}

enum ProjectV2Difficulty {
    BEGINNER
    INTERMEDIATE
    ADVANCED
}

enum UserProjectV2Status {
    NOT_STARTED
    IN_PROGRESS
    SUBMITTED
    COMPLETED
}

enum TaskKanbanStatus {
    TO_DO
    IN_PROGRESS
    COMPLETED
}

enum QuizV2Difficulty {
    EASY
    MEDIUM
    HARD
}

enum FeatureSuggestionType {
    FEATURE
    IMPROVEMENT
    BUG_FIX
    UI_UX
    PERFORMANCE
    DOCUMENTATION
    OTHER
}

enum FeatureSuggestionStatus {
    PENDING
    UNDER_REVIEW
    APPROVED
    REJECTED
    IMPLEMENTED
}

enum SuggestionSource {
    CREATOR
    ENROLLED_USER
    VISITOR
}

enum ProjectErrorSeverity {
    HIGH
    MEDIUM
    LOW
}

enum ProjectErrorCategory {
    SETUP
    CONFIGURATION
    DATABASE
    API
    UI
    STATE
    DEPLOYMENT
    SECURITY
    PERFORMANCE
    OTHER
}

enum ProjectErrorStatus {
    PENDING
    APPROVED
    REJECTED
}

enum ProjectIdeaStatus {
    PENDING
    APPROVED
    REJECTED
}

enum IdeaType {
    PROBLEM_STATEMENT // Technology agnostic - user picks their stack
    TECHNOLOGY_SPECIFIC // Current behavior - specific tech stack
}

// Type of assessment for a task
enum TaskAssessmentType {
    QUIZ // Multiple choice questions about Learns
    CODE // User writes code that is validated
    NONE // No assessment required (optional tasks)
}

// Type of mock session (project-level final or sprint checkpoint)
enum MockSessionType {
    PROJECT_FINAL // Final mock interview for entire project
    SPRINT_REVIEW // Mock interview after completing a sprint
}

model ProjectV2 {
    id                         String              @id @default(cuid())
    slug                       String              @unique
    title                      String
    shortDescription           String?             @db.VarChar(200)
    description                String              @db.Text
    technologies               String[]
    generationType             String // FULL_STACK | FRONTEND | PROGRAMS | AI/ML | AI_AGENT | OTHER
    primaryLanguageOrFramework String?
    difficulty                 ProjectV2Difficulty
    visibility                 ProjectV2Visibility @default(PRIVATE)
    estimatedHours             Int                 @default(20)
    includeAssessment          Boolean             @default(false)

    // Platform / Source tracking
    isPlatformSeeded Boolean @default(false) // True for BuildrHQ curated projects
    projectSource    String  @default("AI_GENERATED") // AI_GENERATED | PLATFORM_SEEDED | USER_SUBMITTED

    // AI Guided Mode
    guidedModeEnabled Boolean @default(true) // AI guidance available

    // Project Overview & Context
    blueprintOverview String   @db.Text // Detailed project summary
    vision            String?  @db.Text // Why this project exists
    targetAudience    String? // Who is this for
    problemSolution   String?  @db.Text // What problem it solves
    estimatedDuration String? // "2-3 weeks", "1 month"
    keyOutcomes       String[] // Specific things user will have built
    recruiterSignal   String?  @db.Text // Why this project matters for hiring

    // Features with priority/complexity
    features Json? // Array of {name, description, priority, complexity}

    // Technical Documentation
    technicalRequirements Json? // {database, authentication, hosting, thirdPartyAPIs}
    dataArchitecture      Json? // {models[], endpoints[]}
    projectStructure      Json? // {description, tree, keyFolders[]}
    setupGuide            Json? // {prerequisites, envVars, installationSteps, verificationSteps}

    // Stacks and assistant payloads
    stacks        Json // normalized from echo.stacks
    assistantEcho Json // echo block sent to assistant
    assistantRaw  Json // full assistant JSON response

    // Stats
    totalStarted     Int @default(0)
    totalCompleted   Int @default(0)
    totalSubmissions Int @default(0)
    totalViews       Int @default(0)

    // Creator
    createdBy String
    creator   User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now()) @updatedAt

    // Relations
    // NOTE: Tasks now go through Sprints (project.sprints[].tasks)
    pages              ProjectV2Page[]
    sprints            ProjectV2Sprint[] // Tasks are nested within sprints
    quiz               ProjectV2Quiz?
    knowledge          ProjectV2KnowledgeBase?
    progress           UserProjectV2Progress[]
    submissions        ProjectV2Submission[]
    taskStatuses       UserTaskV2Status[]
    quizAttempts       ProjectV2QuizAttempt[]
    mockSessions       ProjectV2MockSession[]
    featureSuggestions ProjectV2FeatureSuggestion[]
    leaderboard        ProjectV2Leaderboard[]       @relation("ProjectV2Leaderboard")
    resources          ProjectV2Resource[]          @relation("ProjectV2Resources")
    errors             ProjectV2Error[]             @relation("ProjectV2Errors")
    sourceIdea         ProjectIdea?                 @relation("IdeaBlueprint")
    guidedSessions     ProjectV2GuidedSession[]     @relation("ProjectGuidedSessions")

    // Standup Configuration
    standupConfigs ProjectV2StandupConfig[]

    // Bookmarks
    bookmarks ProjectV2Bookmark[] @relation("ProjectV2Bookmarks")

    projectV2Tasks    ProjectV2Task[]
    // Team Collaboration
    members           ProjectV2Member[]           @relation("ProjectMembers")
    sprintSuggestions ProjectV2SprintSuggestion[] @relation("SprintSuggestions")
    invitations       ProjectV2Invitation[]       @relation("ProjectInvitations")

    // University Integration - for teacher-assigned projects
    isUniversityProject Boolean  @default(false) // If created by a university teacher
    universityId        String? // Link to University model
    teacherMemberId     String? // Link to UniversityMember (teacher who created)
    classIds            String[] // Array of class IDs this project is assigned to

    // University Assignment Config
    assignmentDeadline     DateTime? // Optional deadline for university assignments
    assignmentCredits      Int? // Credits required for this assignment
    assignmentInstructions String?   @db.Text // Additional instructions from teacher

    // Learn Step back-relation (for PROJECT step type - major projects)
    LearnStep LearnStep? @relation("LearnStepProject")

    @@index([createdBy])
    @@index([visibility])
    @@index([difficulty])
    @@index([technologies])
    @@index([createdAt])
    @@index([slug])
    @@index([isPlatformSeeded])
    @@index([projectSource])
    @@index([universityId])
    @@index([isUniversityProject])
}

model ProjectV2Page {
    id                    String              @id @default(cuid())
    projectId             String
    project               ProjectV2           @relation(fields: [projectId], references: [id], onDelete: Cascade)
    name                  String
    difficulty            ProjectV2Difficulty
    coreFeatures          String[]
    recommendedComponents String[]
    orderIndex            Int                 @default(0)

    // Enhanced Page Specifications (NEW)
    route            String? // Route path e.g., "/", "/dashboard"
    purpose          String?  @db.Text // Why this page exists
    estimatedTime    String? // Time to build e.g., "3-4 hours"
    layout           Json? // {type, sections[]}
    components       Json? // Array of {name, type, description, interactivity[]}
    userInteractions String[] // User actions on this page
    dataNeeded       String[] // Data required for this page

    @@index([projectId])
    @@index([orderIndex])
}

model ProjectV2Task {
    id String @id @default(cuid())

    // Task now belongs to Sprint (which belongs to Project)
    // This is a key architectural change - tasks go through sprints
    sprintId String
    sprint   ProjectV2Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

    // Core Task Fields
    title           String
    description     String[] // array of step strings (3-7 steps, no code)
    criteria        String[] // completion criteria (3-5 items)
    hints           String[] // helpful tips (2-4 items)
    badges          String[] // page/component context badges
    tags            String[] // Learn tags
    difficulty      ProjectV2Difficulty
    orderIndex      Int                 @default(0)
    terminalCommand String?

    // Enhanced Task Metadata
    category      String? // setup, frontend, backend, database, testing, deployment, integration
    estimatedTime String? // e.g., "2-3 hours"
    checkpoints   String[] // Clear success criteria/checkpoints
    relatedPages  String[] // Related page names
    dependencies  String[] // Task dependencies (task titles)

    // ========== NEW: Learning Learns & Assessment ==========
    // Learning objectives - what skills/knowledge user gains (3-5 items)
    learningObjectives String[]
    // Prerequisites - prior knowledge needed before this task
    prerequisites      String[]
    // External resources (MDN, W3Schools, YouTube verified) - JSON array of {title, url, type}
    resources          Json?
    // Testing guidelines - what to test/verify for this task (3-5 items)
    testingGuidelines  String[]
    // Detailed Learns with keyPoints, bestPractices, commonMistakes, etc.
    Learns             Json? // Array of TaskLearn objects
    // What kind of assessment is best for this task
    assessmentType     TaskAssessmentType @default(QUIZ)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Task Detail (for additional resources, images, links)
    taskDetail ProjectV2TaskDetail?

    // User progress tracking
    UserTaskV2Status UserTaskV2Status[]

    // Related errors
    errors      ProjectV2Error[] @relation("TaskErrors")
    projectV2   ProjectV2?       @relation(fields: [projectV2Id], references: [id])
    projectV2Id String?

    // Task Assessment attempts by users
    taskAssessments UserTaskV2Assessment[]
    createdBy       String? // User ID of the creator for private tasks

    @@index([sprintId])
    @@index([orderIndex])
    @@index([difficulty])
    @@index([category])
    @@index([sprintId, orderIndex])
    @@index([assessmentType])
}

model UserProjectV2Progress {
    id        String    @id @default(cuid())
    userId    String
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    projectId String
    project   ProjectV2 @relation(fields: [projectId], references: [id], onDelete: Cascade)

    status             UserProjectV2Status @default(NOT_STARTED)
    tasksCompleted     Int                 @default(0)
    totalTasks         Int                 @default(0)
    progressPercentage Float               @default(0)

    // Scoring fields (out of 100)
    totalScore Float @default(0) // Total score out of 100
    tasksScore Float @default(0) // Tasks score (max 50)
    quizScore  Float @default(0) // Quiz score (max 25)
    mockScore  Float @default(0) // Mock interview score (max 25)

    startedAt   DateTime?
    submittedAt DateTime?
    completedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    taskStatuses UserTaskV2Status[]

    @@unique([userId, projectId])
    @@index([userId])
    @@index([projectId])
    @@index([status])
    @@index([totalScore]) // For leaderboard queries
}

model UserTaskV2Status {
    id         String                @id @default(cuid())
    userId     String
    user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
    projectId  String
    project    ProjectV2             @relation(fields: [projectId], references: [id], onDelete: Cascade)
    taskId     String
    task       ProjectV2Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
    progressId String
    progress   UserProjectV2Progress @relation(fields: [progressId], references: [id], onDelete: Cascade)

    status      TaskKanbanStatus @default(TO_DO)
    completedAt DateTime?
    notes       String?          @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([userId, taskId])
    @@index([userId])
    @@index([taskId])
    @@index([projectId])
    @@index([progressId])
    @@index([status])
}

model ProjectV2Quiz {
    id             String                  @id @default(cuid())
    projectId      String                  @unique
    project        ProjectV2               @relation(fields: [projectId], references: [id], onDelete: Cascade)
    totalQuestions Int
    createdAt      DateTime                @default(now())
    updatedAt      DateTime                @updatedAt
    questions      ProjectV2QuizQuestion[]
    attempts       ProjectV2QuizAttempt[]
}

model ProjectV2QuizQuestion {
    id            String           @id @default(cuid())
    quizId        String
    quiz          ProjectV2Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
    orderIndex    Int              @default(0)
    difficulty    QuizV2Difficulty
    prompt        String           @db.Text
    options       String[] // exactly 4 items
    correctAnswer Int // 0-3 index
    explanation   String           @db.Text

    userAnswers ProjectV2QuizAnswer[]

    @@index([quizId])
    @@index([orderIndex])
    @@index([difficulty])
}

model ProjectV2KnowledgeBase {
    id        String    @id @default(cuid())
    projectId String    @unique
    project   ProjectV2 @relation(fields: [projectId], references: [id], onDelete: Cascade)
    points    String[] // concise, high-signal points

    // Mock Interview Knowledge Base
    mockKnowledgeBase String?   @db.Text // Formatted text for ElevenLabs agent
    mockQuestionsData Json? // Structured interview questions data
    mockGeneratedAt   DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model ProjectV2Submission {
    id        String    @id @default(cuid())
    userId    String
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    projectId String
    project   ProjectV2 @relation(fields: [projectId], references: [id], onDelete: Cascade)

    githubUrl String
    liveUrl   String?
    notes     String? @db.Text
    status    String  @default("PENDING") // PENDING | APPROVED | REJECTED
    scores    Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([projectId])
    @@index([status])
}

// Quiz Attempt and Answer Tracking
model ProjectV2QuizAttempt {
    id        String        @id @default(cuid())
    userId    String
    user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    projectId String
    project   ProjectV2     @relation(fields: [projectId], references: [id], onDelete: Cascade)
    quizId    String
    quiz      ProjectV2Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

    score          Int     @default(0) // Score out of 100
    totalQuestions Int     @default(0)
    correctAnswers Int     @default(0)
    timeSpent      Int? // Time in seconds
    isCompleted    Boolean @default(false)

    startedAt   DateTime  @default(now())
    completedAt DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    answers ProjectV2QuizAnswer[]

    @@unique([userId, quizId])
    @@index([userId])
    @@index([projectId])
    @@index([quizId])
    @@index([isCompleted])
}

model ProjectV2QuizAnswer {
    id         String                @id @default(cuid())
    attemptId  String
    attempt    ProjectV2QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
    questionId String
    question   ProjectV2QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

    selectedAnswer Int // User's selected option index (0-3)
    isCorrect      Boolean @default(false)
    timeSpent      Int? // Time in seconds for this question

    createdAt DateTime @default(now())

    @@unique([attemptId, questionId])
    @@index([attemptId])
    @@index([questionId])
    @@index([isCorrect])
}

// AI Mock Interview Sessions (Project-level or Sprint-level)
model ProjectV2MockSession {
    id        String    @id @default(cuid())
    userId    String
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    projectId String
    project   ProjectV2 @relation(fields: [projectId], references: [id], onDelete: Cascade)

    // ========== NEW: Session Type ==========
    sessionType MockSessionType  @default(PROJECT_FINAL)
    // If sprint review, link to specific sprint
    sprintId    String?
    sprint      ProjectV2Sprint? @relation(fields: [sprintId], references: [id], onDelete: Cascade)

    // Session details
    agentId        String? // ElevenLabs agent ID
    conversationId String? // ElevenLabs conversation ID
    duration       Int? // Duration in seconds

    // Scoring
    score              Int? // Overall score out of 100
    technicalScore     Int? // Technical depth score
    communicationScore Int? // Communication score
    LearnualScore      Int? // Learnual understanding score

    // Feedback
    transcript   String?  @db.Text
    feedback     String?  @db.Text
    strengths    String[] // Array of strengths
    improvements String[] // Areas for improvement

    // Status
    status String @default("SCHEDULED") // SCHEDULED | IN_PROGRESS | COMPLETED | FAILED

    scheduledAt DateTime?
    startedAt   DateTime?
    completedAt DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@index([userId])
    @@index([projectId])
    @@index([sprintId])
    @@index([status])
    @@index([completedAt])
    @@index([sessionType])
}

// ===============================================
// TASK-LEVEL ASSESSMENTS (Quiz or Code Challenge)
// ===============================================
// User's attempt at a task assessment (quiz or code)
model UserTaskV2Assessment {
    id String @id @default(cuid())

    userId String
    user   User   @relation("UserTaskAssessments", fields: [userId], references: [id], onDelete: Cascade)

    taskId String
    task   ProjectV2Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

    // Assessment type (mirrors the task's assessmentType)
    assessmentType TaskAssessmentType

    // ========== Quiz Assessment Fields ==========
    // Questions are generated on the fly, stored here after generation
    quizQuestions  Json? // Array of {prompt, options[], correctAnswer, explanation}
    quizAnswers    Json? // Array of {questionIndex, selectedAnswer, isCorrect}
    quizScore      Int? // Score out of 100
    correctAnswers Int   @default(0)
    totalQuestions Int   @default(0)

    // ========== Code Assessment Fields ==========
    // Code submitted by the user
    codeSubmission String? @db.Text
    codeLanguage   String?
    // Validation result (AI-powered)
    codeValidation Json? // {passed: boolean, feedback: string, suggestions: string[]}
    codeScore      Int? // Score out of 100

    // Overall
    passed    Boolean @default(false)
    attempts  Int     @default(1)
    timeSpent Int? // Time in seconds

    startedAt   DateTime  @default(now())
    completedAt DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@unique([userId, taskId]) // One active assessment per user per task
    @@index([userId])
    @@index([taskId])
    @@index([assessmentType])
    @@index([passed])
}

// Feature Suggestions for Projects
model ProjectV2FeatureSuggestion {
    id        String    @id @default(cuid())
    userId    String
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    projectId String
    project   ProjectV2 @relation(fields: [projectId], references: [id], onDelete: Cascade)

    title       String
    description String                @db.Text
    type        FeatureSuggestionType @default(FEATURE)
    tags        String[] // e.g., ["frontend", "backend", "ui"]
    imageUrl    String? // Optional screenshot/mockup

    status FeatureSuggestionStatus @default(PENDING)

    // Track who suggested it
    suggestedBy SuggestionSource @default(VISITOR)

    // Track who adopted this suggestion
    addedByUsers String[] @default([])

    // If approved and added to tasks
    addedToTasks Boolean @default(false)
    taskId       String? // Reference to created task if added

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([projectId])
    @@index([status])
    @@index([type])
    @@index([suggestedBy])
    @@index([createdAt])
}

// Project V2 Resource Library
model ProjectV2Resource {
    id        String    @id @default(cuid())
    userId    String
    user      User      @relation("ProjectV2Resources", fields: [userId], references: [id], onDelete: Cascade)
    projectId String
    project   ProjectV2 @relation("ProjectV2Resources", fields: [projectId], references: [id], onDelete: Cascade)

    title       String       @db.VarChar(200)
    link        String       @db.Text
    type        ResourceType
    description String?      @db.Text

    // Engagement metrics
    helpfulCount    Int      @default(0)
    markedHelpfulBy String[] @default([]) // Array of user IDs who marked as helpful
    views           Int      @default(0)

    // Metadata
    isOfficial Boolean @default(false) // Set by creator

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([projectId])
    @@index([type])
    @@index([createdAt])
    @@index([helpfulCount])
}

// Project V2 Leaderboard (cached rankings)
model ProjectV2Leaderboard {
    id        String    @id @default(cuid())
    userId    String
    user      User      @relation("ProjectV2Leaderboard", fields: [userId], references: [id], onDelete: Cascade)
    projectId String
    project   ProjectV2 @relation("ProjectV2Leaderboard", fields: [projectId], references: [id], onDelete: Cascade)

    rank            Int
    score           Float // Total score out of 100
    tasksCompleted  Int   @default(0)
    totalTasks      Int   @default(0)
    progressPercent Float @default(0)

    // Quick access to component scores
    tasksScore Float @default(0)
    quizScore  Float @default(0)
    mockScore  Float @default(0)

    // Timestamps
    lastUpdated DateTime @default(now())
    createdAt   DateTime @default(now())

    @@unique([userId, projectId])
    @@index([projectId, rank])
    @@index([projectId, score])
    @@index([userId])
}

// Global Projects Leaderboard (aggregated across all projects)
model ProjectV2GlobalLeaderboard {
    id     String @id @default(cuid())
    userId String @unique
    user   User   @relation("ProjectV2GlobalLeaderboard", fields: [userId], references: [id], onDelete: Cascade)

    rank                  Int
    totalScore            Float @default(0) // Sum of all project scores
    projectsStarted       Int   @default(0)
    projectsCompleted     Int   @default(0)
    averageScore          Float @default(0)
    totalTasksCompleted   Int   @default(0)
    totalQuizzesCompleted Int   @default(0)
    totalMocksCompleted   Int   @default(0)

    lastUpdated DateTime @default(now())
    createdAt   DateTime @default(now())

    @@index([rank])
    @@index([totalScore])
    @@index([averageScore])
}

// ===============================================
// PROJECT V2 - TASK DETAILS & STANDUP FEATURES
// ===============================================

// Stores generated detailed sub-tasks for a specific task
// This is shared across all users who request details for the same task
model ProjectV2TaskDetail {
    id     String        @id @default(cuid())
    taskId String        @unique
    task   ProjectV2Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

    // Generated sub-task roadmap
    subTasks Json // Array of {title, description, command?, approach, tips[]}

    // Common errors and pitfalls specific to this task
    commonErrors     String[]
    errorsToWatchout String[]

    // Extra related practice tasks (main tasks, not sub-tasks)
    relatedTasks Json // Array of {title, description, difficulty, why_related}

    // Generation metadata
    generatedBy    String // First user who generated this
    generatedAt    DateTime @default(now())
    generationCost Int      @default(1) // Cost in credits

    // Track how many users have accessed this
    accessCount Int @default(1) // Starts at 1 (the generator)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    userAccess UserTaskV2DetailAccess[]

    @@index([taskId])
}

// Tracks which users have purchased/viewed details for which tasks
model UserTaskV2DetailAccess {
    id           String              @id @default(cuid())
    userId       String
    user         User                @relation("UserTaskDetailAccess", fields: [userId], references: [id], onDelete: Cascade)
    taskDetailId String
    taskDetail   ProjectV2TaskDetail @relation(fields: [taskDetailId], references: [id], onDelete: Cascade)

    // Each user pays 1 credit to access (even if already generated by someone else)
    creditsPaid Int      @default(1)
    accessedAt  DateTime @default(now())

    @@unique([userId, taskDetailId])
    @@index([userId])
    @@index([taskDetailId])
}

// Daily Standup Configuration for a user's project
model ProjectV2StandupConfig {
    id        String    @id @default(cuid())
    userId    String
    projectId String
    project   ProjectV2 @relation(fields: [projectId], references: [id], onDelete: Cascade)

    // Configuration
    daysPerWeek     Int // Minimum 4, maximum 7
    standupTime     String // HH:MM format (e.g., "09:00")
    durationMinutes Int    @default(10) // 5-10 minutes

    // Selected days (0 = Sunday, 6 = Saturday)
    selectedDays Int[] // e.g., [1, 2, 3, 4, 5] for Mon-Fri

    // Pricing and payment
    creditsPerDay Int @default(5) // 5 credits per standup day
    weeklyCredits Int // daysPerWeek * creditsPerDay

    // Status
    isActive         Boolean  @default(true)
    currentWeekStart DateTime @default(now())
    currentWeekEnd   DateTime

    // Stats
    totalStandups     Int @default(0)
    completedStandups Int @default(0)
    missedStandups    Int @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    standupEntries ProjectV2StandupEntry[]

    @@unique([userId, projectId])
    @@index([userId])
    @@index([projectId])
    @@index([isActive])
}

// Individual Standup Entries
model ProjectV2StandupEntry {
    id       String                 @id @default(cuid())
    configId String
    config   ProjectV2StandupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

    // Standup content
    scheduledFor DateTime // When this standup was scheduled
    submittedAt  DateTime? // When user actually submitted

    // Standup questions & answers
    whatDidYesterday String? @db.Text // What did you work on yesterday?
    whatDoingToday   String? @db.Text // What will you work on today?
    anyBlockers      String? @db.Text // Any blockers or challenges?

    // Audio/Video recording (optional)
    recordingUrl    String?
    durationSeconds Int?

    // Status
    status String @default("SCHEDULED") // SCHEDULED | SUBMITTED | MISSED

    // AI Analysis (optional feature)
    aiSummary     String?  @db.Text
    aiSuggestions String[] @default([])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([configId])
    @@index([scheduledFor])
    @@index([status])
}

// Project Ideas submitted by users or seeded
model ProjectIdea {
    id                         String   @id @default(cuid())
    projectTitle               String
    projectDescription         String   @db.Text
    generationType             String
    difficulty                 String
    primaryLanguageOrFramework String?
    technologies               String[]
    categories                 String[]
    technology                 String?

    ideaType               IdeaType @default(TECHNOLOGY_SPECIFIC)
    overview               String?  @db.Text
    coreRequirements       String[]
    engineeringConstraints String[]
    suggestedStacks        Json? // { languages: [], databases: [], queues: [] }
    recruiterSignal        String?  @db.Text

    // Platform curation
    isPlatformCurated Boolean @default(false) // Curated by BuildrHQ team
    curatedQuality    String? // FEATURED | STANDARD | COMMUNITY

    // Build tracking
    buildCount Int @default(0) // How many users built this idea

    // Optional fields for user submissions
    images        String[]
    figmaLinks    String[]
    resourceLinks String[]

    // Stacks JSON
    stacks Json?

    // Blueprint linking (for pre-generated project templates)
    blueprintProjectId    String?    @unique
    blueprintProject      ProjectV2? @relation("IdeaBlueprint", fields: [blueprintProjectId], references: [id])
    hasBlueprintGenerated Boolean    @default(false)
    blueprintGeneratedAt  DateTime?

    // Submission tracking
    status          ProjectIdeaStatus @default(PENDING)
    submittedById   String?
    submittedBy     User?             @relation("SubmittedProjectIdeas", fields: [submittedById], references: [id])
    isUserSubmitted Boolean           @default(false)

    // Engagement
    upvotes Int @default(0)
    views   Int @default(0)

    // Timestamps
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt
    approvedAt DateTime?

    upvotedBy ProjectIdeaUpvote[] @relation("ProjectIdeaUpvotes")

    @@index([technology])
    @@index([status])
    @@index([difficulty])
    @@index([submittedById])
    @@index([createdAt])
    @@index([upvotes])
    @@index([hasBlueprintGenerated])
    @@index([ideaType])
    @@index([isPlatformCurated])
}

// Track who upvoted which project idea
model ProjectIdeaUpvote {
    id            String      @id @default(cuid())
    projectIdeaId String
    projectIdea   ProjectIdea @relation("ProjectIdeaUpvotes", fields: [projectIdeaId], references: [id], onDelete: Cascade)
    userId        String
    createdAt     DateTime    @default(now())

    @@unique([projectIdeaId, userId])
    @@index([projectIdeaId])
    @@index([userId])
}

// ========================================
// PROJECT ERRORS & MISTAKES
// ========================================

// Common errors and mistakes for projects
model ProjectV2Error {
    id String @id @default(cuid())

    projectId String
    project   ProjectV2 @relation("ProjectV2Errors", fields: [projectId], references: [id], onDelete: Cascade)

    // Error details
    title       String               @db.VarChar(200)
    description String               @db.Text
    solution    String               @db.Text
    severity    ProjectErrorSeverity @default(MEDIUM)
    category    ProjectErrorCategory @default(OTHER)

    // Optional: Link to specific task
    taskId String?
    task   ProjectV2Task? @relation("TaskErrors", fields: [taskId], references: [id], onDelete: SetNull)

    // Code examples
    errorCode String? @db.Text // The problematic code
    fixedCode String? @db.Text // The corrected code

    // Tags for filtering
    tags String[]

    // Status for moderation
    status ProjectErrorStatus @default(PENDING)

    // Submission tracking
    submittedById String
    submittedBy   User    @relation("SubmittedProjectErrors", fields: [submittedById], references: [id], onDelete: Cascade)
    isAIGenerated Boolean @default(false) // If generated during project creation

    // Engagement metrics
    helpfulCount     Int @default(0) // Number of "this helped me" votes
    encounteredCount Int @default(0) // Number of "I encountered this" votes

    // Timestamps
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt
    approvedAt DateTime?

    // Relations
    votes ProjectV2ErrorVote[] @relation("ProjectErrorVotes")

    @@index([projectId])
    @@index([taskId])
    @@index([severity])
    @@index([category])
    @@index([status])
    @@index([submittedById])
    @@index([helpfulCount])
    @@index([createdAt])
}

// Track votes on project errors
model ProjectV2ErrorVote {
    id String @id @default(cuid())

    errorId String
    error   ProjectV2Error @relation("ProjectErrorVotes", fields: [errorId], references: [id], onDelete: Cascade)
    userId  String
    user    User           @relation("ProjectErrorVotes", fields: [userId], references: [id], onDelete: Cascade)

    // Vote type
    voteType String // "helpful" or "encountered"

    createdAt DateTime @default(now())

    @@unique([errorId, userId, voteType])
    @@index([errorId])
    @@index([userId])
}

// ===============================================
// PROJECT V2 SPRINT - Sprint-based Task Organization
// ===============================================

model ProjectV2Sprint {
    id        String    @id @default(cuid())
    projectId String
    project   ProjectV2 @relation(fields: [projectId], references: [id], onDelete: Cascade)

    sprintNumber Int // 1, 2, 3, etc.
    name         String // "Sprint 1: Foundation & Setup"
    goal         String @db.Text // What this sprint achieves
    duration     String // Time estimate e.g., "3-5 days", "1 week"
    orderIndex   Int    @default(0)

    // Creator and approval tracking
    createdBy String? // User ID who created this sprint
    creator   User?   @relation("SprintCreator", fields: [createdBy], references: [id])

    isApproved Boolean @default(true) // Whether this sprint counts toward progress
    isPersonal Boolean @default(false) // Personal sprint created by non-creator

    tasks ProjectV2Task[]

    createdAt             DateTime               @default(now())
    updatedAt             DateTime               @updatedAt
    projectV2MockSessions ProjectV2MockSession[]

    @@unique([projectId, sprintNumber])
    @@index([projectId])
    @@index([orderIndex])
    @@index([projectId, orderIndex])
    @@index([createdBy])
}

// ===============================================
// PROJECT V2 TEAM COLLABORATION
// ===============================================

enum ProjectV2MemberRole {
    ADMIN // Project creator or promoted member
    MEMBER // Regular team member with task access
}

enum ProjectV2InvitationStatus {
    PENDING
    ACCEPTED
    DECLINED
    EXPIRED
}

enum SprintSuggestionStatus {
    PENDING // Awaiting creator approval
    APPROVED // Creator approved, sprint created
    REJECTED // Creator rejected
}

// Team Members - for collaborative projects
model ProjectV2Member {
    id        String    @id @default(cuid())
    projectId String
    project   ProjectV2 @relation("ProjectMembers", fields: [projectId], references: [id], onDelete: Cascade)
    userId    String
    user      User      @relation("ProjectMemberships", fields: [userId], references: [id], onDelete: Cascade)

    role      ProjectV2MemberRole @default(MEMBER)
    joinedAt  DateTime            @default(now())
    invitedBy String? // User ID who invited them

    @@unique([projectId, userId])
    @@index([projectId])
    @@index([userId])
}

// Sprint Suggestions - for users suggesting new sprints
model ProjectV2SprintSuggestion {
    id        String    @id @default(cuid())
    projectId String
    project   ProjectV2 @relation("SprintSuggestions", fields: [projectId], references: [id], onDelete: Cascade)

    // Suggested by
    suggestedById String
    suggestedBy   User   @relation("SprintSuggestor", fields: [suggestedById], references: [id], onDelete: Cascade)

    // Sprint details (same structure as ProjectV2Sprint)
    sprintNumber Int
    name         String
    goal         String @db.Text
    duration     String

    // Tasks to be created with this sprint (JSON array)
    suggestedTasks Json? // Array of task definitions

    status SprintSuggestionStatus @default(PENDING)

    // Review
    reviewedById String?
    reviewedBy   User?     @relation("SprintReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
    reviewedAt   DateTime?
    reviewNote   String?   @db.Text

    // If approved, link to created sprint
    createdSprintId String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([projectId])
    @@index([suggestedById])
    @@index([status])
}

// Project Invitations - for inviting users to collaborate
model ProjectV2Invitation {
    id        String    @id @default(cuid())
    projectId String
    project   ProjectV2 @relation("ProjectInvitations", fields: [projectId], references: [id], onDelete: Cascade)

    // Invited user (can be by email or user ID)
    invitedUserId String?
    invitedUser   User?   @relation("ReceivedInvitations", fields: [invitedUserId], references: [id], onDelete: Cascade)
    invitedEmail  String? // For inviting users not yet registered

    // Inviter
    invitedById String
    invitedBy   User   @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)

    role   ProjectV2MemberRole       @default(MEMBER)
    status ProjectV2InvitationStatus @default(PENDING)

    // Token for email-based invitations
    inviteToken String?   @unique
    expiresAt   DateTime?

    respondedAt DateTime?

    createdAt DateTime @default(now())

    @@unique([projectId, invitedUserId])
    @@unique([projectId, invitedEmail])
    @@index([projectId])
    @@index([invitedUserId])
    @@index([invitedEmail])
    @@index([inviteToken])
    @@index([status])
}

// ===============================================
// AI GUIDED SESSIONS - Step-by-step building mode
// ===============================================
model ProjectV2GuidedSession {
    id        String    @id @default(cuid())
    userId    String
    user      User      @relation("UserGuidedSessions", fields: [userId], references: [id], onDelete: Cascade)
    projectId String
    project   ProjectV2 @relation("ProjectGuidedSessions", fields: [projectId], references: [id], onDelete: Cascade)

    // Current step tracking
    currentSprintIndex Int @default(0)
    currentTaskIndex   Int @default(0)
    currentStepIndex   Int @default(0) // Within a task

    // Conversation history (for continuity) - stored as JSON array of messages
    conversationHistory Json? // Array of {role: 'user'|'assistant', content: string, timestamp: string}

    // Session state
    isActive Boolean @default(true)
    mode     String  @default("GUIDED") // GUIDED | SELF_PACED

    // Initial system context (pre-generated for platform projects)
    systemContext String? @db.Text // System prompt with project context

    startedAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([userId, projectId])
    @@index([userId])
    @@index([projectId])
    @@index([isActive])
}
