// ===============================================
// OPEN SOURCE HUB - COMPLETE SYSTEM
// ===============================================

enum OSProjectType {
    LEARNING // Practice projects in learn module
    FREE // Community/free contribution projects
    PAID // Bounty projects from companies
    EXCLUSIVE // Premium/invite-only projects
}

enum OSProjectCategory {
    WEB_DEVELOPMENT
    MOBILE_DEVELOPMENT
    BACKEND
    FULLSTACK
    AI_ML
    DEVOPS
    BLOCKCHAIN
    GAME_DEVELOPMENT
    OTHER
}

enum OSProjectStatus {
    DRAFT // Being set up
    ACTIVE // Open for contributions
    PAUSED // Temporarily closed
    COMPLETED // All issues resolved
    ARCHIVED // No longer active
}

enum OSIssueStatus {
    OPEN // Available to claim
    ASSIGNED // Someone is working on it
    IN_REVIEW // PR submitted, under review
    COMPLETED // Merged successfully
    CLOSED // Closed without merge
}

enum OSIssueDifficulty {
    GOOD_FIRST_ISSUE // For beginners
    EASY // Simple tasks
    MEDIUM // Moderate complexity
    HARD // Complex tasks
    EXPERT // Advanced/architecture level
}

enum OSContributionType {
    ISSUE_CREATED // Created an issue
    ISSUE_SOLVED // Solved an issue
    PR_SUBMITTED // Submitted a PR
    PR_MERGED // PR was merged
    CODE_REVIEW // Reviewed someone's code
    DOCUMENTATION // Added docs
    BUG_FIX // Fixed a bug
    FEATURE // Added new feature
}

enum OSContributionStatus {
    PENDING // Awaiting review
    IN_REVIEW // Being reviewed
    APPROVED // Approved
    REJECTED // Rejected
    MERGED // Merged to main
    CHANGES_REQUESTED // Needs modifications
}

enum OSLearnModuleType {
    VIDEO // Video content
    READING // Text content
    INTERACTIVE // Hands-on lab
    QUIZ // Knowledge check
    PROJECT // Mini project
}

enum OSCertificationStatus {
    NOT_STARTED // Haven't begun
    IN_PROGRESS // Currently taking
    PASSED // Successfully completed
    FAILED // Failed (can retry)
}

// Main Open Source Project Model
model OpenSourceProject {
    id          String          @id @default(cuid())
    slug        String          @unique
    title       String
    description String          @db.Text
    longDescription String?     @db.Text
    
    // GitHub Integration
    githubRepoUrl   String
    githubOwner     String // e.g., "coderz-org"
    githubRepo      String // e.g., "awesome-project"
    defaultBranch   String      @default("main")
    
    // Project Details
    type            OSProjectType   @default(FREE)
    category        OSProjectCategory @default(WEB_DEVELOPMENT)
    status          OSProjectStatus @default(DRAFT)
    technologies    String[]
    tags            String[]
    difficulty      OSIssueDifficulty @default(MEDIUM)
    
    // Learning Goals (for LEARNING type projects)
    learningGoals   String[]    // What students will learn
    prerequisites   String[]    // What students should know
    estimatedHours  Int?        // Hours to complete
    
    // Bounty Info (for PAID projects)
    totalBudget     Float       @default(0)
    remainingBudget Float       @default(0)
    currency        String      @default("USD")
    
    // Company Info (for PAID/EXCLUSIVE)
    companyName     String?
    companyLogo     String?
    companyUrl      String?
    
    // Stats (synced from GitHub)
    totalIssues         Int @default(0)
    openIssues          Int @default(0)
    closedIssues        Int @default(0)
    totalContributors   Int @default(0)
    totalPRsMerged      Int @default(0)
    totalPRsOpen        Int @default(0)
    totalCommits        Int @default(0)
    stars               Int @default(0)
    forks               Int @default(0)
    watchers            Int @default(0)
    
    // Last GitHub sync
    lastSyncedAt    DateTime?
    syncError       String?
    
    // Settings
    requiresCertification Boolean @default(true) // Must pass OS certification
    maxActiveIssues       Int     @default(2) // Max issues per contributor
    prDeadlineHours       Int     @default(48) // Hours to submit PR
    maxContributionsPerUser Int   @default(0) // 0 = unlimited
    
    // README content (cached from GitHub)
    readmeContent   String?     @db.Text
    contributingGuide String?   @db.Text
    
    // Cover/Banner
    coverImage      String?
    bannerImage     String?
    
    // Order for displaying
    orderIndex      Int         @default(0)
    isFeatured      Boolean     @default(false)
    
    // Maintainer (admin/moderator)
    maintainerId    String?
    maintainer      User?   @relation("OSProjectMaintainer", fields: [maintainerId], references: [id])
    
    // Created by (admin or company)
    createdById     String
    createdBy       User    @relation("OSProjectCreator", fields: [createdById], references: [id])
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    // Relations
    issues          OSIssue[]
    contributions   OSContribution[]
    contributors    OSProjectContributor[]
    leaderboard     OSProjectLeaderboard[]
    setupGuide      OSProjectSetupGuide?
    
    @@index([type])
    @@index([category])
    @@index([status])
    @@index([maintainerId])
    @@index([createdById])
    @@index([slug])
    @@index([orderIndex])
    @@index([isFeatured])
}

// Project Setup Guide (step-by-step instructions)
model OSProjectSetupGuide {
    id          String          @id @default(cuid())
    
    projectId   String          @unique
    project     OpenSourceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
    
    // Setup steps (JSON array of steps)
    steps       Json            // Array of { title, description, commands, expectedOutput }
    
    // Environment requirements
    nodeVersion String?
    npmPackages String[]
    envVariables Json?          // Required env variables
    
    // Local development instructions
    installCommand  String      @default("npm install")
    devCommand      String      @default("npm run dev")
    buildCommand    String      @default("npm run build")
    testCommand     String      @default("npm test")
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

// Issues within a project
model OSIssue {
    id          String          @id @default(cuid())
    projectId   String
    project     OpenSourceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
    
    // GitHub Integration
    githubIssueNumber   Int?
    githubIssueUrl      String?
    githubIssueId       String?     // GitHub issue ID for API
    
    // Issue Details
    title           String
    description     String  @db.Text
    requirements    String[] // What needs to be done
    acceptanceCriteria String[] // How to know it's done
    hints           String[] // Helpful tips
    
    // Learning context (what students will learn from this issue)
    learningGoals   String[]
    filesToModify   String[]    // List of files to be modified
    relatedDocs     String[]    // Related documentation links
    
    // Classification
    status          OSIssueStatus       @default(OPEN)
    difficulty      OSIssueDifficulty   @default(EASY)
    labels          String[]
    estimatedHours  Int         @default(4)
    
    // Bounty (for PAID issues)
    bountyAmount    Float   @default(0)
    bountyPaid      Boolean @default(false)
    
    // Assignment
    assignedToId    String?
    assignedTo      User?   @relation("OSIssueAssignee", fields: [assignedToId], references: [id])
    assignedAt      DateTime?
    deadlineAt      DateTime?
    
    // PR info (when submitted)
    prNumber        Int?
    prUrl           String?
    prStatus        String?     // open, closed, merged
    
    // Stats
    totalAttempts   Int @default(0)
    orderIndex      Int @default(0)
    
    // Synced from GitHub
    lastSyncedAt    DateTime?
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    // Relations
    contributions   OSContribution[]
    
    @@index([projectId])
    @@index([status])
    @@index([difficulty])
    @@index([assignedToId])
    @@index([githubIssueNumber])
    @@index([orderIndex])
}

// User contributions (PRs, reviews, etc.)
model OSContribution {
    id          String          @id @default(cuid())
    
    projectId   String
    project     OpenSourceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
    
    issueId     String?
    issue       OSIssue?        @relation(fields: [issueId], references: [id])
    
    userId      String
    user        User            @relation("OSContributions", fields: [userId], references: [id], onDelete: Cascade)
    
    // Contribution Details
    type            OSContributionType
    status          OSContributionStatus @default(PENDING)
    
    // GitHub Integration
    githubPrNumber  Int?
    githubPrUrl     String?
    githubPrId      String?     // GitHub PR ID for API
    githubCommitSha String?
    githubBranch    String?     // Branch name used for contribution
    
    // Fork info
    forkRepoUrl     String?     // User's fork URL
    forkOwner       String?     // User's GitHub username
    
    // Content
    title           String?
    description     String? @db.Text
    
    // Review
    reviewScore     Int?    // AI/Manual score 0-100
    reviewFeedback  String? @db.Text
    reviewCycles    Int     @default(0) // Number of revision cycles
    
    // Reviewer (maintainer)
    reviewedById    String?
    reviewedBy      User?   @relation("OSContributionReviewer", fields: [reviewedById], references: [id])
    reviewedAt      DateTime?
    
    // Rewards
    xpEarned        Int     @default(0)
    bountyEarned    Float   @default(0)
    
    // Quality metrics (synced from GitHub)
    linesAdded      Int     @default(0)
    linesRemoved    Int     @default(0)
    filesChanged    Int     @default(0)
    commitsCount    Int     @default(0)
    testsPassing    Boolean @default(true)
    
    // GitHub PR status details
    isMerged        Boolean @default(false)
    mergedAt        DateTime?
    mergedBy        String?
    closedAt        DateTime?
    
    // Checks status
    checksStatus    String?     // pending, success, failure
    checksDetails   Json?       // CI/CD check details
    
    // Last sync from GitHub
    lastSyncedAt    DateTime?
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    @@index([projectId])
    @@index([issueId])
    @@index([userId])
    @@index([type])
    @@index([status])
    @@index([githubPrNumber])
    @@index([isMerged])
}

// Project contributors tracking
model OSProjectContributor {
    id          String          @id @default(cuid())
    
    projectId   String
    project     OpenSourceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
    
    userId      String
    user        User            @relation("OSProjectContributors", fields: [userId], references: [id], onDelete: Cascade)
    
    // Stats
    totalContributions  Int @default(0)
    prsSubmitted        Int @default(0)
    prsMerged           Int @default(0)
    issuesSolved        Int @default(0)
    reviewsGiven        Int @default(0)
    totalXpEarned       Int @default(0)
    totalBountyEarned   Float @default(0)
    
    // Ranking
    rank            Int?
    contributionScore Float @default(0)
    
    // Status
    isActive        Boolean @default(true)
    
    joinedAt    DateTime @default(now())
    lastActiveAt DateTime @default(now())
    
    @@unique([projectId, userId])
    @@index([projectId])
    @@index([userId])
    @@index([rank])
}

// Project Leaderboard
model OSProjectLeaderboard {
    id          String          @id @default(cuid())
    
    projectId   String
    project     OpenSourceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
    
    userId      String
    user        User            @relation("OSProjectLeaderboard", fields: [userId], references: [id], onDelete: Cascade)
    
    rank            Int
    score           Float
    prsMerged       Int
    issuesSolved    Int
    bountyEarned    Float @default(0)
    
    updatedAt   DateTime @updatedAt
    
    @@unique([projectId, userId])
    @@index([projectId, rank])
}

// ===============================================
// OPEN SOURCE LEARNING SYSTEM
// ===============================================

// Learning Module (e.g., "Git Basics", "GitHub Workflow")
model OSLearnModule {
    id          String          @id @default(cuid())
    slug        String          @unique
    title       String
    description String          @db.Text
    icon        String?
    coverImage  String?
    
    // Module settings
    orderIndex      Int         @default(0)
    isRequired      Boolean     @default(true) // Required for certification
    estimatedMinutes Int        @default(30)
    
    // Stats
    totalEnrolled   Int @default(0)
    totalCompleted  Int @default(0)
    averageScore    Float @default(0)
    
    isActive    Boolean @default(true)
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    // Relations
    lessons     OSLearnLesson[]
    progress    OSLearnProgress[]
    
    @@index([orderIndex])
    @@index([isRequired])
}

// Lessons within a module
model OSLearnLesson {
    id          String          @id @default(cuid())
    moduleId    String
    module      OSLearnModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
    
    title       String
    description String?
    type        OSLearnModuleType @default(READING)
    
    // Content
    content     String? @db.Text // Markdown content for READING
    videoUrl    String? // For VIDEO type
    
    // Interactive content (for INTERACTIVE type)
    interactiveData Json? // Commands to run, expected outputs, etc.
    
    // Code Lab content (for CODE type)
    codeLab     Json?   // { language, starterCode, expectedOutput, hints, solution }
    
    // Terminal Lab content (for TERMINAL type)
    terminalLab Json?   // { commands, expectedOutputs, validations }
    
    // Quiz content (for QUIZ type)
    quizQuestions   Json? // Array of quiz questions
    passingScore    Int     @default(70) // Percentage to pass
    
    // Settings
    orderIndex      Int     @default(0)
    estimatedMinutes Int    @default(10)
    isRequired      Boolean @default(true)
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    // Relations
    completions OSLessonCompletion[]
    
    @@index([moduleId])
    @@index([orderIndex])
}

enum OSLearnLabType {
    CODE        // Code writing exercise
    TERMINAL    // Git/terminal commands
    QUIZ        // Multiple choice
    PROJECT     // Mini project
}

// User progress on modules
model OSLearnProgress {
    id          String          @id @default(cuid())
    
    userId      String
    user        User            @relation("OSLearnProgress", fields: [userId], references: [id], onDelete: Cascade)
    
    moduleId    String
    module      OSLearnModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
    
    // Progress
    lessonsCompleted    Int     @default(0)
    totalLessons        Int     @default(0)
    progressPercent     Float   @default(0)
    
    // Quiz performance
    quizScore           Int?
    quizAttempts        Int     @default(0)
    
    isCompleted Boolean @default(false)
    completedAt DateTime?
    
    startedAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    @@unique([userId, moduleId])
    @@index([userId])
    @@index([moduleId])
}

// Individual lesson completions
model OSLessonCompletion {
    id          String          @id @default(cuid())
    
    userId      String
    user        User            @relation("OSLessonCompletions", fields: [userId], references: [id], onDelete: Cascade)
    
    lessonId    String
    lesson      OSLearnLesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
    
    // Completion details
    score       Int?    // For quiz lessons
    timeSpent   Int     @default(0) // Seconds
    
    // Interactive lesson results
    commandsRun Json?   // Commands user ran and outputs
    
    isCompleted Boolean @default(false)
    completedAt DateTime?
    
    createdAt   DateTime @default(now())
    
    @@unique([userId, lessonId])
    @@index([userId])
    @@index([lessonId])
}

// ===============================================
// OPEN SOURCE CERTIFICATION
// ===============================================

// Certification Exam
model OSCertificationExam {
    id          String          @id @default(cuid())
    
    userId      String
    user        User            @relation("OSCertificationExams", fields: [userId], references: [id], onDelete: Cascade)
    
    // Exam Details
    status      OSCertificationStatus @default(NOT_STARTED)
    
    // Section scores
    quizScore           Int?    // Quiz section score (0-100)
    codeScore           Int?    // Code exercises score (0-100)
    scenarioScore       Int?    // Scenario questions score (0-100)
    
    totalScore          Int?    // Overall score (0-100)
    passingScore        Int     @default(75) // Required to pass
    
    // Exam content (randomized per user)
    quizQuestions       Json?   // Randomized quiz questions
    codeExercises       Json?   // Code exercises
    scenarioQuestions   Json?   // Scenario-based questions
    
    // User answers
    quizAnswers         Json?
    codeAnswers         Json?
    scenarioAnswers     Json?
    
    // Timing
    startedAt       DateTime?
    completedAt     DateTime?
    timeLimit       Int     @default(60) // Minutes
    
    // Attempts
    attemptNumber   Int     @default(1)
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    @@index([userId])
    @@index([status])
}

// Certification awarded to user
model OSCertification {
    id              String  @id @default(cuid())
    certificateId   String  @unique // Unique certificate ID for verification
    
    userId      String
    user        User    @relation("OSCertifications", fields: [userId], references: [id], onDelete: Cascade)
    
    // Certificate Details
    title       String  @default("Open Source Contributor Certification")
    score       Int     // Final exam score
    
    // Validity
    issuedAt    DateTime @default(now())
    expiresAt   DateTime // 2 years from issue
    isActive    Boolean  @default(true)
    
    // Verification
    verificationUrl String?
    qrCode          String?
    
    @@index([userId])
    @@index([certificateId])
}

// ===============================================
// USER OPEN SOURCE STATS (for dashboard)
// ===============================================

model UserOSStats {
    id          String  @id @default(cuid())
    
    userId      String  @unique
    user        User    @relation("UserOSStats", fields: [userId], references: [id], onDelete: Cascade)
    
    // Learning stats
    modulesCompleted    Int @default(0)
    lessonsCompleted    Int @default(0)
    totalLearningTime   Int @default(0) // Minutes
    
    // Certification
    isCertified         Boolean @default(false)
    certificationScore  Int?
    certifiedAt         DateTime?
    
    // Contribution stats
    totalProjects       Int @default(0)
    totalContributions  Int @default(0)
    prsSubmitted        Int @default(0)
    prsMerged           Int @default(0)
    issuesSolved        Int @default(0)
    reviewsGiven        Int @default(0)
    
    // Quality metrics
    avgPrScore          Float @default(0)
    acceptanceRate      Float @default(0) // % of PRs merged
    
    // Earnings
    totalBountyEarned   Float @default(0)
    pendingBounty       Float @default(0)
    
    // XP & Ranking
    osXp                Int @default(0)
    globalRank          Int?
    
    // Streak
    currentStreak       Int @default(0)
    longestStreak       Int @default(0)
    lastContributionAt  DateTime?
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    @@index([userId])
    @@index([globalRank])
}

// Bounty/Earnings transactions
model OSEarningsTransaction {
    id          String  @id @default(cuid())
    
    userId      String
    user        User    @relation("OSEarningsTransactions", fields: [userId], references: [id], onDelete: Cascade)
    
    // Transaction details
    type        String  // BOUNTY_EARNED, WITHDRAWAL, CONVERTED_TO_CREDITS
    amount      Float
    currency    String  @default("USD")
    
    // Reference
    projectId   String?
    issueId     String?
    contributionId String?
    
    // Status
    status      String  @default("COMPLETED") // PENDING, COMPLETED, FAILED
    
    // Payout details
    payoutMethod    String? // BANK, PAYPAL, CREDITS
    payoutDetails   Json?
    
    createdAt   DateTime @default(now())
    
    @@index([userId])
    @@index([type])
    @@index([status])
}

// ===============================================
// GITHUB USER INTEGRATION
// ===============================================

model OSGitHubProfile {
    id          String  @id @default(cuid())
    
    userId      String  @unique
    user        User    @relation("OSGitHubProfile", fields: [userId], references: [id], onDelete: Cascade)
    
    // GitHub Profile Info
    githubId        String  @unique  // GitHub user ID
    githubUsername  String           // GitHub username
    githubName      String?          // GitHub display name
    githubAvatar    String?          // Avatar URL
    githubBio       String?          // Bio
    githubLocation  String?          // Location
    githubCompany   String?          // Company
    githubBlog      String?          // Blog URL
    
    // GitHub Stats
    publicRepos     Int     @default(0)
    publicGists     Int     @default(0)
    followers       Int     @default(0)
    following       Int     @default(0)
    
    // OAuth tokens (encrypted)
    accessToken     String?  // GitHub access token for API calls
    refreshToken    String?  // GitHub refresh token if applicable
    tokenExpiresAt  DateTime?
    
    // Scope of access
    scopes          String[]  // OAuth scopes granted
    
    // Sync status
    lastSyncedAt    DateTime?
    syncError       String?
    
    // Preferences
    showOnProfile   Boolean @default(true)  // Show GitHub stats on profile
    autoSync        Boolean @default(true)  // Auto-sync contributions
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    @@index([githubUsername])
    @@index([githubId])
}

// ===============================================
// LEARNING PRACTICE PROJECTS
// ===============================================

// Practice project for learning module (simulated, not real GitHub)
model OSLearnPracticeProject {
    id          String  @id @default(cuid())
    
    moduleId    String?
    
    slug        String  @unique
    title       String
    description String  @db.Text
    
    // Project type
    techStack   String[]    // e.g., ["HTML", "CSS", "JavaScript"]
    category    OSProjectCategory @default(WEB_DEVELOPMENT)
    difficulty  OSIssueDifficulty @default(EASY)
    
    // Content
    starterFiles    Json    // { filename: content } structure
    solutionFiles   Json?   // Solution files
    
    // Learning context
    learningGoals   String[]
    prerequisites   String[]
    estimatedHours  Int     @default(2)
    
    // Practice issues/tasks
    orderIndex      Int     @default(0)
    isActive        Boolean @default(true)
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    // Relations
    tasks           OSLearnPracticeTask[]
    completions     OSLearnPracticeCompletion[]
    
    @@index([slug])
    @@index([difficulty])
    @@index([orderIndex])
}

// Tasks within a practice project
model OSLearnPracticeTask {
    id          String  @id @default(cuid())
    
    projectId   String
    project     OSLearnPracticeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
    
    title       String
    description String  @db.Text
    
    // Task requirements
    requirements    String[]
    hints           String[]
    
    // Files to modify
    targetFiles     String[]
    
    // Validation (AI will check against this)
    validationRules Json?   // Rules for AI to check
    expectedChanges Json?   // Expected code changes
    
    // Classification
    difficulty      OSIssueDifficulty @default(EASY)
    estimatedMinutes Int    @default(30)
    xpReward        Int     @default(50)
    
    orderIndex      Int     @default(0)
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    // Relations
    submissions     OSLearnPracticeSubmission[]
    
    @@index([projectId])
    @@index([orderIndex])
}

// User submissions for practice tasks
model OSLearnPracticeSubmission {
    id          String  @id @default(cuid())
    
    userId      String
    taskId      String
    task        OSLearnPracticeTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
    
    // Submission content
    submittedCode   Json    // { filename: content }
    
    // AI Review
    isCorrect       Boolean @default(false)
    score           Int?    // 0-100
    feedback        String? @db.Text
    aiReview        Json?   // Detailed AI feedback
    
    // Attempts
    attemptNumber   Int     @default(1)
    
    // XP awarded
    xpEarned        Int     @default(0)
    
    createdAt   DateTime @default(now())
    
    @@index([userId])
    @@index([taskId])
}

// User practice project completions
model OSLearnPracticeCompletion {
    id          String  @id @default(cuid())
    
    userId      String
    projectId   String
    project     OSLearnPracticeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
    
    // Progress
    tasksCompleted  Int     @default(0)
    totalTasks      Int     @default(0)
    progressPercent Float   @default(0)
    
    // Completion status
    isCompleted     Boolean @default(false)
    completedAt     DateTime?
    
    // Stats
    totalXpEarned   Int     @default(0)
    totalAttempts   Int     @default(0)
    averageScore    Float   @default(0)
    
    startedAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    @@unique([userId, projectId])
    @@index([userId])
    @@index([projectId])
}