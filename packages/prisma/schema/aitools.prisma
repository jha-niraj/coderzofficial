model JobInterviewAssistant {
    id               String  @id @default(cuid())
    userId           String
    position         String
    jobDescription   String  @db.Text
    companyUrl       String
    companyInfo      Json?
    generatedContent Json
    includeAnswers   Boolean @default(false)
    includePractice  Boolean @default(false)
    searchHash       String?
    slug             String  @unique @default("niraj jha")

    // Question counts
    technicalCount  Int @default(8)
    behavioralCount Int @default(8)
    codingCount     Int @default(3)

    // Public/Private functionality
    isPublic    Boolean @default(false)
    publicCost  Int? // Cost in credits for public access
    description String? // Plan description
    creditsCost Int? // Original cost of generation

    // Analytics
    purchaseCount Int      @default(0) // Number of times this plan has been purchased
    viewCount     Int      @default(0) // Number of times this plan has been viewed
    rating        Float? // Average rating from users
    tags          String[] @default([]) // Tags for categorization

    createdAt             DateTime               @default(now())
    updatedAt             DateTime               @updatedAt
    user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
    codeEvaluations       CodeEvaluation[]
    questionAnswers       QuestionAnswer[]
    userQuestionResponses UserQuestionResponse[]

    // Track purchases of this public plan
    purchases   InterviewPlanPurchase[] @relation("PublicInterviewPurchases")
    // Track new plans created when purchased
    purchasedAs InterviewPlanPurchase[] @relation("PurchasedInterviewPlan")

    @@index([userId])
    @@index([searchHash])
    @@index([isPublic])
    @@index([position])
}

model CodeEvaluation {
    id           String   @id @default(cuid())
    questionText String   @db.Text
    userCode     String   @db.Text
    language     String
    evaluation   Json? // AI evaluation result
    score        Int? // Score out of 100
    feedback     String?  @db.Text
    strengths    String[] // Array of strengths
    improvements String[] // Array of areas for improvement
    isSubmitted  Boolean  @default(false) // Distinguishes between "Run" and "Submit"
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    // Relations
    interviewId String
    interview   JobInterviewAssistant @relation(fields: [interviewId], references: [id], onDelete: Cascade)

    @@index([interviewId])
    @@index([language])
    @@index([isSubmitted])
}

model QuestionAnswer {
    id           String   @id @default(cuid())
    questionText String   @db.Text
    questionType String // 'technical', 'behavioral', 'coding'
    language     String? // Programming language for coding questions
    answer       Json // Stores the AI-generated answer
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    // Relations
    interviewId String
    interview   JobInterviewAssistant @relation(fields: [interviewId], references: [id], onDelete: Cascade)

    @@unique([interviewId, questionText, language])
    @@index([interviewId])
    @@index([questionType])
    @@index([language])
}

// New model for storing user responses to technical and behavioral questions
model UserQuestionResponse {
    id                String   @id @default(cuid())
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
    interviewId       String
    questionText      String   @db.Text
    questionType      String
    questionIndex     Int
    userAnswer        String   @db.Text
    answerMethod      String   @default("text")
    score             Int
    feedback          String   @db.Text
    strengths         String[]
    improvements      String[]
    comparedToExpert  Json
    evaluationDetails Json? // Store detailed evaluation breakdown

    interview JobInterviewAssistant @relation(fields: [interviewId], references: [id], onDelete: Cascade)

    @@unique([interviewId, questionType, questionIndex])
}

// Interview Plan Purchase Models
model InterviewPlanPurchase {
    id                 String                 @id @default(cuid())
    buyerId            String // Just store the user ID
    interviewPlanId    String
    interviewPlan      JobInterviewAssistant  @relation("PublicInterviewPurchases", fields: [interviewPlanId], references: [id])
    cost               Int
    purchasedAt        DateTime               @default(now())
    // Reference to the new interview plan created for the buyer
    newInterviewPlanId String?
    newInterviewPlan   JobInterviewAssistant? @relation("PurchasedInterviewPlan", fields: [newInterviewPlanId], references: [id])
}

model CoverLetter {
    id               String   @id @default(cuid())
    userId           String
    jobUrl           String
    companyName      String?
    jobTitle         String?
    jobDescription   String?  @db.Text
    questions        Json? // AI generated questions
    answers          Json? // User answers
    tone             String?  @default("Professional")
    generatedContent String?  @db.Text
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt
    user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

// ===============================================
// RESUME TEMPLATE SYSTEM
// ===============================================

model ResumeTemplate {
    id              String  @id @default(cuid())
    slug            String  @unique
    name            String
    description     String  @db.Text
    previewImageUrl String
    sectionOrder    Json
    isDefault       Boolean @default(false)
    creditsCost     Int     @default(10)

    // Platform vs user-created
    isPlatform  Boolean @default(false)
    createdById String?
    createdBy   User?   @relation("UserCreatedTemplates", fields: [createdById], references: [id], onDelete: SetNull)

    // Forge marketplace
    isMarketplace    Boolean @default(false)
    isFeatured       Boolean @default(false)
    marketplacePrice Int     @default(0)
    config           Json? // custom styling { primaryColor, font, layout }

    // Stats
    totalSales   Int      @default(0)
    totalRevenue Int      @default(0)
    tags         String[] @default([])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    generations ResumeTemplateGeneration[]
    purchases   TemplatePurchase[]          @relation("TemplatePurchases")
}

model ResumeTemplateGeneration {
    id               String   @id @default(cuid())
    userId           String
    templateId       String
    generatedContent Json?
    createdAt        DateTime @default(now())

    user     User           @relation("UserResumeTemplateGenerations", fields: [userId], references: [id], onDelete: Cascade)
    template ResumeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([templateId])
    @@index([userId, templateId])
}
// ===============================================
// RESUME DRAFT SYSTEM
// ===============================================

model ResumeDraft {
    id           String  @id @default(cuid())
    userId       String
    name         String  // "Google SWE Resume"
    templateSlug String  @default("clean-minimal")

    // Full content snapshot (independent from live profile)
    content Json // { header, experience, projects, education, skills, certifications }

    // Job targeting
    tailoredFor String?
    jdSnapshot  String?  @db.Text
    atsScore    Int?

    // Sharing
    isPublic  Boolean @default(false)
    shareSlug String  @unique @default(cuid())
    viewCount Int     @default(0)

    // Import metadata
    importedFrom String? // "linkedin" | "github" | "pdf" | "manual" | "profile"
    importedUrl  String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation("UserResumeDrafts", fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([shareSlug])
    @@index([isPublic])
}

// ===============================================
// TEMPLATE MARKETPLACE
// ===============================================

model TemplatePurchase {
    id              String @id @default(cuid())
    buyerId         String
    templateId      String
    pricePaid       Int // credits paid
    creatorEarning  Int // 90%
    platformFee     Int // 10%

    createdAt DateTime @default(now())

    buyer    User           @relation("TemplatePurchasesBuyer", fields: [buyerId], references: [id])
    template ResumeTemplate @relation("TemplatePurchases", fields: [templateId], references: [id])

    @@unique([buyerId, templateId])
    @@index([buyerId])
    @@index([templateId])
}
