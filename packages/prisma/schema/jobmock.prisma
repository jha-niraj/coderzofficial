// ============================================
// JOB MOCK INTERVIEW SCHEMA
// Models for company-specific mock interviews
// Tied to interview processes and jobs
// ============================================

// Interview Process Configuration
// Companies MUST configure this to enable transparency
model InterviewProcess {
    id        String @id @default(cuid())
    companyId String

    // Process Details
    name                          String   // e.g., "Software Engineer Interview Process"
    description                   String?  @db.Text
    isDefault                     Boolean  @default(false) // Default process for new jobs
    estimatedDurationWeeks        Float?   // e.g., 2.5 weeks
    avgTimeToHireDays             Int?
    responseRatePercent           Float?   // % of applications that get responses
    applicationToInterviewPercent Float?   // % that move to interview
    interviewToOfferPercent       Float?   // % that get offers

    // Status
    isActive Boolean @default(true)

    // Relations
    company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
    rounds  InterviewRound[]
    jobs    Job[]            @relation("JobInterviewProcess")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([companyId])
    @@index([isDefault])
}

// Individual Interview Rounds
model InterviewRound {
    id        String @id @default(cuid())
    processId String

    // Round Details
    roundNumber Int // 1, 2, 3, etc.
    roundType   InterviewRoundType
    title       String // e.g., "Phone Screen", "Technical Coding"
    
    // Duration & Format
    durationMinutes Int?
    format          InterviewFormat @default(VIDEO)

    // Candidate-Facing Information (Transparency)
    description          String  @db.Text // What candidates should expect
    whatToExpect         Json? // Array of bullet points
    sampleQuestions      Json? // Array of sample questions
    evaluationCriteria   Json? // Array of criteria
    topicsCovered        Json? // Array of topics
    tipsForCandidates    Json? // Array of tips

    // Statistics (helps set expectations)
    passRatePercent      Float? // % that pass this round
    daysToNextRound      Int? // Average days to next round

    // Internal Notes (not visible to candidates)
    internalNotes String? @db.Text
    interviewerGuide     String? @db.Text

    // Mock Interview Integration
    hasMockInterview     Boolean @default(true) // Enable AI mock for this round
    mockKnowledgeBase    String? @db.Text // Custom knowledge base for AI interviewer

    // Relations
    process      InterviewProcess       @relation(fields: [processId], references: [id], onDelete: Cascade)
    mockSessions JobMockSession[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([processId, roundNumber])
    @@index([processId])
    @@index([roundType])
}

enum InterviewRoundType {
    PHONE_SCREEN
    TECHNICAL_CODING
    SYSTEM_DESIGN
    BEHAVIORAL
    TAKE_HOME
    PANEL
    HIRING_MANAGER
    CULTURE_FIT
    HR_FINAL
    CUSTOM
}

enum InterviewFormat {
    VOICE // Phone call
    VIDEO // Video call
    IN_PERSON // On-site
    TAKE_HOME // Async assignment
    LIVE_CODING // Screen share + coding
    WHITEBOARD // System design
}

// Job Mock Interview Sessions
// Tracks student's practice sessions for specific company interviews
model JobMockSession {
    id String @id @default(cuid())

    // Core Relations
    userId    String // Student who is practicing
    jobId     String? // Optional: specific job they're preparing for
    companyId String // Company whose interview they're practicing
    roundId   String // Specific round they're practicing

    // Session Details
    sessionType JobMockSessionType @default(VOICE)
    status      JobMockStatus      @default(SCHEDULED)

    // ElevenLabs Integration (for voice)
    conversationId String? @unique
    agentId        String?

    // Dynamic Variables for AI
    variables Json? // { username, position, company_name, round_info, knowledge_base }

    // Session Timing
    scheduledFor DateTime?
    startedAt    DateTime?
    completedAt  DateTime?
    durationSeconds Int?

    // Audio & Transcript (for voice)
    recordingUrl  String?
    transcriptUrl String?
    transcript    String? @db.Text

    // Code Submission (for coding)
    codeSubmission String? @db.Text
    codeLanguage   String?
    testResults    Json? // { passed: 3, failed: 1, total: 4 }

    // System Design (for design rounds)
    diagramUrl String?
    designNotes String? @db.Text

    // AI Analysis & Scoring
    overallScore Int? // 0-100
    aiAnalysis   Json? // Detailed analysis
    categoryScores Json? // { communication: 85, technical: 78, problem_solving: 90 }
    
    // Strengths & Improvements
    strengths    Json? // Array of strength areas
    improvements Json? // Array of improvement suggestions

    // Comparison
    percentileRank Int? // How they compare to others
    trend          String? // "improving", "stable", "declining"

    // User Feedback
    userRating   Int? // 1-5 stars
    userFeedback String? @db.Text

    // Credits
    creditsUsed Int @default(15)

    // Relations
    user    User           @relation("UserJobMockSessions", fields: [userId], references: [id], onDelete: Cascade)
    round   InterviewRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
    company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
    job     Job?           @relation("JobMockSessions", fields: [jobId], references: [id], onDelete: SetNull)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([jobId])
    @@index([companyId])
    @@index([roundId])
    @@index([status])
    @@index([conversationId])
}

enum JobMockSessionType {
    VOICE // Voice interview (ElevenLabs)
    CODING // Coding challenge
    SYSTEM_DESIGN // Whiteboard/design
    BEHAVIORAL // Behavioral questions
}

enum JobMockStatus {
    SCHEDULED
    IN_PROGRESS
    COMPLETED
    CANCELLED
    FAILED
}

// Track interview preparation progress per application
model InterviewPrepProgress {
    id            String @id @default(cuid())
    applicationId String
    userId        String

    // Overall Progress
    overallReadinessScore Int @default(0) // 0-100
    targetReadinessScore  Int @default(80)

    // Round-wise Progress
    roundsCompleted Int @default(0)
    totalRounds     Int @default(0)

    // Last Practice
    lastPracticedAt   DateTime?
    totalPracticeSessions Int @default(0)
    totalPracticeMinutes  Int @default(0)

    // Best Scores per Round Type
    bestScores Json? // { phone_screen: 85, coding: 78, system_design: 72 }

    // Recommendations
    nextRecommendedRound String? // Round ID to practice next
    recommendedResources Json? // Array of resource links

    // Relations
    user        User           @relation("UserInterviewPrepProgress", fields: [userId], references: [id], onDelete: Cascade)
    application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([applicationId])
    @@index([userId])
}
