// ============================================
// JOBS & APPLICATIONS SCHEMA
// Models for Job listings and User applications
// ============================================

// Jobs posted by companies
model Job {
    id         String @id @default(cuid())
    companyId  String
    postedById String // CompanyMember who posted the job

    // Basic Info
    title            String
    slug             String @unique
    description      String @db.Text
    requirements     Json? // Skills, experience, education requirements
    responsibilities Json?
    benefits         Json?

    // Location
    location     String?
    locationType JobLocationType @default(REMOTE)

    // Job Details
    employmentType  EmploymentType @default(FULL_TIME)
    experienceMin   Int?
    experienceMax   Int?
    salaryMin       Int?
    salaryMax       Int?
    salaryCurrency  String         @default("INR")
    salaryDisclosed Boolean        @default(true)

    // Skills
    skillsRequired  Json @default("[]") // String array
    skillsPreferred Json @default("[]") // String array

    // Assignment Integration
    hasAssignment          Boolean @default(false)
    assignmentStudioId     String? // References studio for assignment
    assignmentProjectId    String? // Template project for cloning
    assignmentDeadlineDays Int? // Days after application to complete
    evaluationCriteria     Json? // { codeQuality: 25, functionality: 30, etc }
    assignmentDetails      Json? // { title, description, requirements[], resources[], deliverables[] }
    assignmentInstructions String? @db.Text // Detailed instructions for assignment

    // Job Status
    status     JobStatus     @default(DRAFT)
    visibility JobVisibility @default(PUBLIC)
    featured   Boolean       @default(false)

    // Metrics
    viewsCount        Int @default(0)
    applicationsCount Int @default(0)

    // Smart Matching
    matchingCriteria Json? // For smart recommendations

    // Interview Process (for transparency)
    interviewProcessId String? // Links to company's interview process

    // Dates
    expiresAt   DateTime?
    publishedAt DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    // Relations
    company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
    postedBy           CompanyMember       @relation("PostedBy", fields: [postedById], references: [id])
    applications       JobApplication[]
    recommendations    JobRecommendation[]
    interviewProcess   InterviewProcess?   @relation("JobInterviewProcess", fields: [interviewProcessId], references: [id])
    mockSessions       JobMockSession[]    @relation("JobMockSessions")

    @@index([companyId])
    @@index([slug])
    @@index([status])
    @@index([locationType])
    @@index([employmentType])
    @@index([postedById])
}

enum JobLocationType {
    REMOTE
    HYBRID
    ONSITE
}

enum EmploymentType {
    FULL_TIME
    PART_TIME
    CONTRACT
    INTERNSHIP
    FREELANCE
}

enum JobStatus {
    DRAFT
    ACTIVE
    PAUSED
    CLOSED
    FILLED
}

enum JobVisibility {
    PUBLIC
    INVITE_ONLY
}

// Job Applications by users
model JobApplication {
    id     String @id @default(cuid())
    jobId  String
    userId String // References User.id from main schema

    // Application Status
    status ApplicationStatus @default(INTERESTED)
    currentStage Int? // Current interview round number (1, 2, 3...)

    // Preparation Tracking
    preparationStatus Json    @default("{\"profile_complete\": false, \"resume_reviewed\": false, \"mock_interview_done\": false, \"concepts_reviewed\": false, \"assignment_started\": false, \"assignment_completed\": false}")
    preparationScore  Int     @default(0)
    isReadyToApply    Boolean @default(false)

    // Assignment Tracking
    assignmentProjectCloneId String?
    assignmentStartedAt      DateTime?
    assignmentSubmittedAt    DateTime?
    assignmentScore          Int?
    assignmentFeedback       String?   @db.Text

    // Interview Tracking
    interviewId          String?
    interviewScheduledAt DateTime?
    interviewCompletedAt DateTime?
    interviewFeedback    Json?

    // HR Actions
    reviewedById    String? // CompanyMember who reviewed
    reviewedAt      DateTime?
    rejectionReason String?   @db.Text
    hrNotes         String?   @db.Text

    // Match Score (calculated)
    matchScore Int? // 0-100 based on profile vs job requirements

    // Cover letter / notes from candidate
    coverLetter String? @db.Text
    resumeUrl   String? // Link to resume file

    // Timestamps
    appliedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    // Relations
    user         User                    @relation("UserJobApplications", fields: [userId], references: [id], onDelete: Cascade)
    job          Job                     @relation(fields: [jobId], references: [id], onDelete: Cascade)
    reviewedBy   CompanyMember?          @relation("ReviewedBy", fields: [reviewedById], references: [id])
    activities   ApplicationActivity[]
    prepProgress InterviewPrepProgress?  // Preparation progress for this application

    @@unique([jobId, userId])
    @@index([jobId])
    @@index([userId])
    @@index([status])
    @@index([reviewedById])
}

enum ApplicationStatus {
    INTERESTED // User showed interest, added to "My Jobs"
    PREPARING // User is actively preparing for this job
    APPLIED // User submitted application
    UNDER_REVIEW // HR is reviewing
    SHORTLISTED // Passed initial screening
    ASSIGNMENT_SENT // Assignment sent to candidate
    ASSIGNMENT_SUBMITTED // Candidate submitted assignment
    INTERVIEW_SCHEDULED // Interview has been scheduled
    INTERVIEWED // Interview completed
    OFFER_EXTENDED // Offer made to candidate
    HIRED // Candidate accepted offer
    REJECTED // Application rejected
    WITHDRAWN // Candidate withdrew application
}

// Track user activities for each job application
model ApplicationActivity {
    id            String                  @id @default(cuid())
    applicationId String
    userId        String
    activityType  ApplicationActivityType
    activityId    String? // Reference to the actual activity (e.g., mock interview ID)
    metadata      Json?
    score         Int? // If activity has a score
    completedAt   DateTime?
    createdAt     DateTime                @default(now())

    // Relations
    user        User           @relation("UserApplicationActivities", fields: [userId], references: [id], onDelete: Cascade)
    application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

    @@index([applicationId])
    @@index([userId])
    @@index([activityType])
}

enum ApplicationActivityType {
    MOCK_INTERVIEW
    AI_RESUME_REVIEW
    CONCEPT_REVIEW
    PROJECT_PROGRESS
    STUDIO_NOTE
    SKILL_ASSESSMENT
    ASSIGNMENT_PROGRESS
    ASSIGNMENT_SUBMISSION
}

// Smart job recommendations tracking
model JobRecommendation {
    id           String    @id @default(cuid())
    userId       String
    jobId        String
    matchScore   Int // 0-100
    matchReasons Json? // { skill_match: 85, experience_match: 90, location_match: 100 }
    isDismissed  Boolean   @default(false)
    isSaved      Boolean   @default(false)
    viewedAt     DateTime?
    createdAt    DateTime  @default(now())

    // Relations
    user User @relation("UserJobRecommendations", fields: [userId], references: [id], onDelete: Cascade)
    job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

    @@unique([userId, jobId])
    @@index([userId])
    @@index([jobId])
    @@index([matchScore])
}

// User's saved/bookmarked jobs
model SavedJob {
    id        String   @id @default(cuid())
    userId    String
    jobId     String
    notes     String?  @db.Text // User's personal notes about the job
    createdAt DateTime @default(now())

    // Relations
    user User @relation("UserSavedJobs", fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, jobId])
    @@index([userId])
}