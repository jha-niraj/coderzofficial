// ============================================
// KNOWME MODULE - AI-Powered Portfolio Assistant
// ============================================
// This module enables users to create an AI chatbot
// that knows everything about their professional profile
// ============================================

// ============================================
// ENUMS
// ============================================

enum KnowMeStatus {
    INACTIVE // Not set up
    SETUP // In onboarding
    PROCESSING // Creating embeddings
    ACTIVE // Ready to use
    PAUSED // Temporarily disabled
    ERROR // Something went wrong
}

enum KnowMePrivacy {
    PUBLIC // Anyone with link
    REGISTERED // Only logged-in users
    RECRUITERS // Only verified recruiters
    PRIVATE // Only owner
}

enum KnowMePlatform {
    GITHUB
    LEETCODE
    STACKOVERFLOW
    LINKEDIN
    DEVTO
    HASHNODE
    CODEPEN
    DRIBBBLE
}

enum KnowMeSyncStatus {
    PENDING
    SYNCING
    COMPLETED
    FAILED
}

enum KnowMeDataType {
    PROFILE // Basic profile info
    PROJECT // Coderz projects
    ASSESSMENT // Assessment results
    RESUME // Uploaded resume
    COVER_LETTER // Cover letter
    CUSTOM_BIO // Custom bio text
    GITHUB_REPO // GitHub repository
    GITHUB_CONTRIBUTION // GitHub contributions
    LEETCODE_PROBLEM // LeetCode problem stats
    STACKOVERFLOW_ANSWER // SO answers
    LINKEDIN_EXPERIENCE // LinkedIn work history
    OTHER // Other data
}

enum KnowMeJobStatus {
    QUEUED
    PROCESSING
    COMPLETED
    FAILED
    CANCELLED
}

enum KnowMeJobType {
    FULL_SYNC // Full data sync
    INCREMENTAL // Only changed data
    PLATFORM_SYNC // Specific platform sync
    MANUAL_UPDATE // User triggered update
}

enum KnowMeQuestionCategory {
    TECHNICAL_SKILLS
    PROJECTS
    WORK_EXPERIENCE
    EDUCATION
    ASSESSMENTS
    AVAILABILITY
    COMPENSATION
    SOFT_SKILLS
    GENERAL
    OTHER
}

enum KnowMeViewerType {
    OWNER // Profile owner
    REGISTERED_USER // Logged-in user
    RECRUITER // Verified recruiter
    ANONYMOUS // Anonymous visitor
    EXTERNAL_API // Via external API
}

// ============================================
// MAIN PROFILE TABLE
// ============================================

model KnowMeProfile {
    id     String @id @default(cuid())
    userId String @unique
    user   User   @relation("UserKnowMeProfile", fields: [userId], references: [id], onDelete: Cascade)

    // Status
    status   KnowMeStatus  @default(INACTIVE)
    privacy  KnowMePrivacy @default(PUBLIC)
    isPublic Boolean       @default(true)

    // Data Source Toggles
    includePersonalData Boolean @default(true)
    includePlatformData Boolean @default(false)
    includeProjects     Boolean @default(true)
    includeAssessments  Boolean @default(true)
    includeResume       Boolean @default(true)

    // Update Settings
    updateCycleDays      Int       @default(10) // 3, 5, 10 days
    lastUpdatedAt        DateTime?
    nextScheduledUpdate  DateTime?
    totalEmbeddingsCount Int       @default(0)
    lastEmbeddingVersion String?

    // API Settings
    apiKey         String?  @unique
    apiKeyHash     String? // Hashed version for security
    apiEnabled     Boolean  @default(false)
    apiRateLimit   Int      @default(100) // Per day
    apiUsageToday  Int      @default(0)
    apiUsageTotal  Int      @default(0)
    apiLastResetAt DateTime @default(now())

    // Stats
    totalQuestionsAnswered Int @default(0)
    totalSessions          Int @default(0)
    totalVisitors          Int @default(0)
    totalExternalRequests  Int @default(0)

    // Onboarding
    onboardingStep      Int      @default(0)
    onboardingCompleted Boolean  @default(false)
    onboardingStartedAt DateTime @default(now())

    // AI Configuration
    aiPersonality      String?  @db.Text // Custom AI personality prompt
    welcomeMessage     String? // Custom welcome message
    suggestedQuestions String[] // Custom suggested questions

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    personalData        KnowMePersonalData[]
    platformConnections KnowMePlatformConnection[]
    externalData        KnowMeExternalData[]
    embeddings          KnowMeEmbedding[]
    embeddingJobs       KnowMeEmbeddingJob[]
    chatSessions        KnowMeChatSession[]
    questionAnalytics   KnowMeQuestionAnalytics[]
    apiRequests         KnowMeApiRequest[]
    privacySettings     KnowMePrivacySettings?
    profileViews        KnowMeProfileView[]

    @@index([userId])
    @@index([status])
    @@index([apiKey])
}

// ============================================
// PERSONAL DATA (Resume, Cover Letter, etc.)
// ============================================

model KnowMePersonalData {
    id        String        @id @default(cuid())
    profileId String
    profile   KnowMeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    dataType KnowMeDataType
    title    String?
    fileName String?
    fileUrl  String? // S3/storage URL
    fileSize Int? // Size in KB

    contentText String? @db.Text // Extracted/raw text content
    contentHash String? // Hash to detect changes

    isActive  Boolean @default(true)
    isIndexed Boolean @default(false) // Has been embedded

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([profileId])
    @@index([dataType])
    @@index([isActive])
}

// ============================================
// PLATFORM CONNECTIONS (GitHub, LeetCode, etc.)
// ============================================
model KnowMePlatformConnection {
    id        String        @id @default(cuid())
    profileId String
    profile   KnowMeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    platform         KnowMePlatform
    platformUsername String?
    platformUserId   String?
    profileUrl       String?

    // Connection Status
    connectionStatus KnowMeSyncStatus @default(PENDING)
    isConnected      Boolean          @default(false)

    // OAuth Tokens (encrypted in production)
    accessToken    String?   @db.Text
    refreshToken   String?   @db.Text
    tokenExpiresAt DateTime?

    // Sync Settings
    syncFrequencyDays Int       @default(10)
    lastSyncedAt      DateTime?
    nextSyncAt        DateTime?
    lastSyncError     String?

    // Stats from Platform
    metadata Json? // Platform-specific stats
    // Example: { repos: 45, stars: 234, contributions: 450 }

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    externalData KnowMeExternalData[]

    @@unique([profileId, platform])
    @@index([profileId])
    @@index([platform])
    @@index([connectionStatus])
}

// ============================================
// EXTERNAL DATA (Scraped from platforms)
// ============================================
model KnowMeExternalData {
    id           String                    @id @default(cuid())
    profileId    String
    profile      KnowMeProfile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
    connectionId String?
    connection   KnowMePlatformConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)

    dataType   KnowMeDataType
    externalId String? // ID from external platform

    title       String?
    description String? @db.Text
    url         String?

    // Normalized Data
    techStack   String[]
    dateCreated DateTime?
    dateUpdated DateTime?

    // Platform-specific Metrics
    metrics Json?
    // GitHub: { stars: 45, forks: 12, commits: 234 }
    // LeetCode: { difficulty: 'medium', acceptance: 45.2 }

    rawData Json? // Full original data for reference

    isActive  Boolean @default(true)
    isIndexed Boolean @default(false)

    // Deduplication
    isDuplicate              Boolean @default(false)
    mergedWithCoderProjectId String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([profileId, connectionId, externalId])
    @@index([profileId])
    @@index([dataType])
    @@index([isActive])
}

// ============================================
// EMBEDDINGS (Vector metadata - actual vectors in Upstash)
// ============================================
model KnowMeEmbedding {
    id        String        @id @default(cuid())
    profileId String
    profile   KnowMeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    // Source Reference
    sourceType KnowMeDataType
    sourceId   String // Reference to source entity

    // Chunk Information
    chunkIndex Int     @default(0)
    chunkText  String  @db.Text // The text that was embedded
    chunkHash  String? // Hash to detect changes

    // Vector Store Reference
    vectorId        String // ID in Upstash Vector
    vectorNamespace String // Usually the profileId
    vectorScore     Float? // Last retrieval score

    // Embedding Model Info
    embeddingModel   String @default("text-embedding-3-small")
    embeddingVersion Int    @default(1)
    dimensions       Int    @default(1024)

    // Metadata for Retrieval
    metadata Json?
    // { type: 'project', title: 'E-commerce', tech: ['React'] }

    isActive Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([profileId])
    @@index([sourceType])
    @@index([vectorId])
    @@index([isActive])
}

// ============================================
// EMBEDDING JOBS (Queue for processing)
// ============================================
model KnowMeEmbeddingJob {
    id        String        @id @default(cuid())
    profileId String
    profile   KnowMeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    jobType  KnowMeJobType
    status   KnowMeJobStatus @default(QUEUED)
    priority Int             @default(5) // 1-10, lower is higher priority

    // Job Scope
    scope Json?
    // { personalData: true, platforms: ['github'], entities: [{type, id}] }

    // Progress
    progress       Int @default(0) // 0-100
    totalItems     Int @default(0)
    processedItems Int @default(0)
    failedItems    Int @default(0)

    // Results
    result    Json? // Success/error details
    errorLogs String[] // Array of error messages

    // Timestamps
    scheduledFor DateTime?
    startedAt    DateTime?
    completedAt  DateTime?
    createdAt    DateTime  @default(now())

    // Retries
    attempts    Int @default(0)
    maxAttempts Int @default(3)

    @@index([profileId])
    @@index([status])
    @@index([scheduledFor])
}

// ============================================
// CHAT SESSIONS
// ============================================
model KnowMeChatSession {
    id        String        @id @default(cuid())
    profileId String
    profile   KnowMeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    // Visitor Info
    visitorUserId String? // Null if anonymous
    visitorUser   User?   @relation("KnowMeVisitorSessions", fields: [visitorUserId], references: [id], onDelete: SetNull)

    viewerType       KnowMeViewerType @default(ANONYMOUS)
    visitorIp        String?
    visitorUserAgent String?
    visitorCountry   String?
    visitorCity      String?
    visitorReferrer  String?

    // Session Token (for anonymous users)
    sessionToken String @unique @default(cuid())

    // Stats
    questionsAsked Int @default(0)
    messagesCount  Int @default(0)

    // Rate Limiting
    rateLimitRemaining Int      @default(20)
    rateLimitResetAt   DateTime @default(now())

    // Source
    source String? // 'direct', 'profile_link', 'external_api', 'embed'

    // Timestamps
    startedAt      DateTime  @default(now())
    lastActivityAt DateTime  @default(now())
    endedAt        DateTime?

    // Relations
    messages KnowMeChatMessage[]

    @@index([profileId])
    @@index([visitorUserId])
    @@index([sessionToken])
    @@index([startedAt])
}

// ============================================
// CHAT MESSAGES
// ============================================
model KnowMeChatMessage {
    id        String            @id @default(cuid())
    sessionId String
    session   KnowMeChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    role    String // 'user' | 'assistant' | 'system'
    content String @db.Text

    // For AI Responses
    retrievedChunks Json? // Which embeddings were used
    modelUsed       String? // 'gpt-4o-mini', etc.
    tokensUsed      Int?
    responseTimeMs  Int?
    confidence      Float? // 0-1 confidence score

    // Sources
    sources Json? // Links to projects, etc.
    // [{ type: 'project', title: 'X', url: '...' }]

    // Feedback
    wasHelpful Boolean?
    feedback   String?

    createdAt DateTime @default(now())

    @@index([sessionId])
    @@index([createdAt])
}

// ============================================
// QUESTION ANALYTICS
// ============================================
model KnowMeQuestionAnalytics {
    id        String        @id @default(cuid())
    profileId String
    profile   KnowMeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    question         String                 @db.Text
    questionCategory KnowMeQuestionCategory @default(OTHER)
    questionKeywords String[]

    // Who Asked
    askedByUserId String?
    askedByUser   User?            @relation("KnowMeQuestionsAsked", fields: [askedByUserId], references: [id], onDelete: SetNull)
    askedByType   KnowMeViewerType @default(ANONYMOUS)

    // Response Info
    responseGenerated Boolean  @default(true)
    responseTimeMs    Int?
    responseTokens    Int?
    wasHelpful        Boolean?

    // Source
    source String? // 'direct', 'external_api', etc.

    askedAt DateTime @default(now())

    @@index([profileId])
    @@index([questionCategory])
    @@index([askedAt])
    @@index([askedByUserId])
}

// ============================================
// PROFILE VIEWS
// ============================================
model KnowMeProfileView {
    id        String        @id @default(cuid())
    profileId String
    profile   KnowMeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    // Viewer Info
    viewerUserId String?
    viewerUser   User?   @relation("KnowMeProfileViews", fields: [viewerUserId], references: [id], onDelete: SetNull)

    viewerType KnowMeViewerType @default(ANONYMOUS)
    viewerIp   String?

    // Session Info
    sessionDurationSeconds Int?
    questionsAsked         Int     @default(0)
    source                 String? // 'direct', 'search', etc.
    referrer               String?

    viewedAt DateTime @default(now())

    @@index([profileId])
    @@index([viewerUserId])
    @@index([viewedAt])
}

// ============================================
// API REQUESTS (For external portfolio integration)
// ============================================
model KnowMeApiRequest {
    id        String        @id @default(cuid())
    profileId String
    profile   KnowMeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    apiKey   String
    endpoint String // '/api/v1/knowme/chat'
    method   String // 'POST'

    // Request Info
    requestIp      String?
    requestHeaders Json?
    requestBody    Json?

    // Response Info
    responseStatus Int?
    responseTimeMs Int?

    // Usage
    tokensUsed Int?
    costUsd    Float?

    createdAt DateTime @default(now())

    @@index([profileId])
    @@index([apiKey])
    @@index([createdAt])
}

// ============================================
// PRIVACY SETTINGS
// ============================================
model KnowMePrivacySettings {
    id        String        @id @default(cuid())
    profileId String        @unique
    profile   KnowMeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    // Who Can Access
    allowAnonymous       Boolean @default(true)
    allowRegisteredUsers Boolean @default(true)
    allowRecruiters      Boolean @default(true)

    // What Can Be Shared
    shareBasicInfo    Boolean @default(true)
    shareProjects     Boolean @default(true)
    shareAssessments  Boolean @default(true)
    shareWorkHistory  Boolean @default(false)
    shareEducation    Boolean @default(true)
    shareSalary       Boolean @default(false)
    shareExternalData Json    @default("{\"github\": true, \"leetcode\": true}")

    // Rate Limits
    maxQuestionsPerSession  Int     @default(20)
    requireAuthForSensitive Boolean @default(true)

    // Blocked Entities
    blockedUserIds   String[]
    blockedCompanies String[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([profileId])
}

// ============================================
// CREDIT TRANSACTIONS FOR KNOWME
// ============================================
model KnowMeCreditTransaction {
    id     String @id @default(cuid())
    userId String
    user   User   @relation("KnowMeCreditTransactions", fields: [userId], references: [id], onDelete: Cascade)

    transactionType String // 'manual_update', 'upgrade_cycle', 'api_usage'
    amount          Int // Negative for spending

    reason String?

    balanceBefore Int
    balanceAfter  Int

    metadata Json?

    createdAt DateTime @default(now())

    @@index([userId])
    @@index([createdAt])
}
