// ===============================================
// CONCEPTS HUB MODELS
// ===============================================
model Concept {
    id          String @id @default(cuid())
    slug        String @unique
    title       String
    description String @db.Text

    // Categorization
    category       ConceptCategory   @default(PROGRAMMING_FUNDAMENTALS)
    customCategory String? // For CUSTOM category
    difficulty     ConceptDifficulty @default(BEGINNER)
    tags           String[]

    // Media
    thumbnail   String?
    coverImage  String?
    iconEmoji   String? @default("📚")
    accentColor String? @default("#3B82F6")

    // Status & Publishing
    status      ConceptStatus @default(DRAFT)
    publishedAt DateTime?

    // Metadata
    estimatedTime Int?     @default(10) // in minutes
    prerequisites String[]

    // Engagement
    viewCount     Int @default(0)
    likeCount     Int @default(0)
    bookmarkCount Int @default(0)
    commentCount  Int @default(0)

    // SEO
    metaTitle       String?
    metaDescription String?

    // Creator
    creatorId String
    creator   User   @relation("ConceptCreator", fields: [creatorId], references: [id], onDelete: Cascade)

    // Relations
    steps     ConceptStep[]     @relation("ConceptSteps")
    likes     ConceptLike[]     @relation("ConceptLikes")
    bookmarks ConceptBookmark[] @relation("ConceptBookmarks")
    comments  ConceptComment[]  @relation("ConceptComments")
    views     ConceptView[]     @relation("ConceptViews")
    progress  ConceptProgress[] @relation("ConceptProgress")

    // Space relation
    spaceId String?
    space   Space?  @relation("SpaceConcepts", fields: [spaceId], references: [id], onDelete: SetNull)

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([slug])
    @@index([category])
    @@index([difficulty])
    @@index([status])
    @@index([creatorId])
    @@index([createdAt])
    @@index([likeCount])
    @@index([viewCount])
    @@index([spaceId])
}

model ConceptStep {
    id String @id @default(cuid())

    conceptId String
    concept   Concept @relation("ConceptSteps", fields: [conceptId], references: [id], onDelete: Cascade)

    // Step Content
    order Int
    title String
    type  ConceptStepType @default(EXPLANATION)

    // Content (varies by type)
    content String @db.Text

    // For CODE type
    codeBlocks ConceptCodeBlock[] @relation("StepCodeBlocks")
    language   String?            @default("javascript")

    // For VISUALIZATION type
    visualizationType String? // "flowchart", "diagram", "animation"
    visualizationData Json?

    // For COMPARISON type
    comparisonItems Json? // [{title, content, pros, cons}]

    // For QUIZ type
    quizQuestion    String?
    quizOptions     Json? // [{id, text, isCorrect}]
    quizExplanation String? @db.Text

    // For CHALLENGE type
    challengeDescription String?  @db.Text
    challengeStarterCode String?  @db.Text
    challengeSolution    String?  @db.Text
    challengeHints       String[]
    challengeTestCases   Json?

    // Tips/Notes for the step
    tips String[]

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([conceptId, order])
    @@index([conceptId])
    @@index([type])
}

model ConceptCodeBlock {
    id String @id @default(cuid())

    stepId String
    step   ConceptStep @relation("StepCodeBlocks", fields: [stepId], references: [id], onDelete: Cascade)

    // Code Content
    order       Int     @default(0)
    title       String?
    language    String  @default("javascript")
    code        String  @db.Text
    explanation String? @db.Text

    // Settings
    highlightLines  Int[] // Lines to highlight
    showLineNumbers Boolean @default(true)
    isRunnable      Boolean @default(false)

    createdAt DateTime @default(now())

    @@index([stepId])
}

model ConceptLike {
    id String @id @default(cuid())

    conceptId String
    concept   Concept @relation("ConceptLikes", fields: [conceptId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("ConceptLikes", fields: [userId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@unique([conceptId, userId])
    @@index([conceptId])
    @@index([userId])
}

model ConceptBookmark {
    id String @id @default(cuid())

    conceptId String
    concept   Concept @relation("ConceptBookmarks", fields: [conceptId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("ConceptBookmarks", fields: [userId], references: [id], onDelete: Cascade)

    // Optional folder/collection
    folder String? @default("Saved")
    notes  String? @db.Text

    createdAt DateTime @default(now())

    @@unique([conceptId, userId])
    @@index([conceptId])
    @@index([userId])
    @@index([folder])
}

model ConceptComment {
    id String @id @default(cuid())

    conceptId String
    concept   Concept @relation("ConceptComments", fields: [conceptId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("ConceptCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)

    // Comment Content
    content String @db.Text

    // Reply System
    parentId String?
    parent   ConceptComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
    replies  ConceptComment[] @relation("CommentReplies")

    // Engagement
    likeCount Int @default(0)

    // Moderation
    isEdited Boolean @default(false)
    isPinned Boolean @default(false)
    isHidden Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([conceptId])
    @@index([userId])
    @@index([parentId])
    @@index([createdAt])
}

model ConceptView {
    id String @id @default(cuid())

    conceptId String
    concept   Concept @relation("ConceptViews", fields: [conceptId], references: [id], onDelete: Cascade)

    userId String?
    user   User?   @relation("ConceptViews", fields: [userId], references: [id], onDelete: SetNull)

    // Analytics
    source         String? // "browse", "search", "direct", "recommendation"
    duration       Int? // Time spent in seconds
    stepsViewed    Int     @default(0)
    completedSteps Int     @default(0)

    viewedAt DateTime @default(now())

    @@index([conceptId])
    @@index([userId])
    @@index([viewedAt])
}

model ConceptProgress {
    id String @id @default(cuid())

    conceptId String
    concept   Concept @relation("ConceptProgress", fields: [conceptId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation("ConceptProgress", fields: [userId], references: [id], onDelete: Cascade)

    // Progress Tracking
    currentStep     Int   @default(0)
    completedSteps  Int[] // Array of completed step orders
    totalSteps      Int   @default(0)
    progressPercent Float @default(0)

    // Quiz Answers (for quiz steps)
    quizAnswers Json? // {stepId: {selectedOption, isCorrect}}

    // Challenge Submissions
    challengeSubmissions Json? // {stepId: {code, passed}}

    // Status
    isCompleted Boolean   @default(false)
    completedAt DateTime?

    // Time Tracking
    totalTimeSpent Int      @default(0) // in seconds
    lastAccessedAt DateTime @default(now())

    // Timestamps
    startedAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([conceptId, userId])
    @@index([conceptId])
    @@index([userId])
    @@index([isCompleted])
    @@index([lastAccessedAt])
}

model ConceptRequest {
    id String @id @default(cuid())

    // Requester
    userId String
    user   User   @relation("ConceptRequests", fields: [userId], references: [id], onDelete: Cascade)

    // Request Details
    title       String
    description String             @db.Text
    category    ConceptCategory?
    difficulty  ConceptDifficulty?

    // Status
    status ConceptRequestStatus @default(PENDING)

    // Admin Response
    adminNotes String? @db.Text
    assignedTo String? // Admin who took the request

    // Upvotes (for community requests)
    upvotes Int @default(0)

    // Result
    resultConceptId String? // Link to created concept if fulfilled

    // Timestamps
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt
    resolvedAt DateTime?

    @@index([userId])
    @@index([status])
    @@index([category])
    @@index([upvotes])
    @@index([createdAt])
}