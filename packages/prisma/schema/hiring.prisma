// ============================================
// HIRING PLATFORM SCHEMA
// Models for Company/HR side of the platform
// ============================================

// Role type for members within a company
// FOUNDER: First person to register - full admin access
// ADMIN: Full admin access (can do everything except remove founder)
// HIRING_MANAGER: Can post jobs, manage candidates, conduct interviews
// RECRUITER: Standard recruiter access (can post jobs, review candidates)
// INTERVIEWER: Can only view assigned candidates and submit feedback
enum CompanyMemberRole {
    FOUNDER // First registrant - cannot be removed, full control
    ADMIN // Full admin access (almost like founder)
    HIRING_MANAGER // Department-level hiring authority
    RECRUITER // Standard recruiter role
    INTERVIEWER // Limited access - only for interviews
}

// Job Title for the user in the company (for display purposes)
enum CompanyMemberJobTitle {
    CEO
    CTO
    COFOUNDER
    VP_ENGINEERING
    ENGINEERING_MANAGER
    HR_HEAD
    HR_MANAGER
    TALENT_ACQUISITION
    RECRUITER
    HIRING_MANAGER
    TECH_LEAD
    INTERVIEWER
    OTHER
}

// Companies that post jobs
model Company {
    id           String  @id @default(cuid())
    name         String
    slug         String  @unique
    logoUrl      String?
    website      String?
    description  String? @db.Text
    industry     String?
    companySize  String? // "1-10", "11-50", "51-200", "201-500", "500+"
    foundedYear  Int?
    headquarters String?
    socialLinks  Json? // { linkedin, twitter, github }

    // Location fields
    address String?
    city    String?
    state   String?
    country String?
    pincode String?

    // Company Culture & Benefits
    culture     String? @db.Text
    benefits    Json? // Array of benefits
    techStack   Json? // Array of technologies used
    mediaGallery Json? // Array of image URLs

    // Company Stats (for transparency)
    responseRatePercent   Float? // % of applications that get responses
    avgTimeToHireDays     Int?   // Average days from apply to offer
    interviewToOfferPercent Float? // % that get offers after interview
    totalHired            Int    @default(0)
    totalApplications     Int    @default(0)

    // Verification (for platform trust)
    verificationStatus CompanyVerificationStatus @default(PENDING)
    verifiedAt         DateTime?
    verifiedBy         String? // Admin user ID who verified

    // Invite code for company workspace
    inviteCode String? @unique

    // The User who created/registered the company
    createdByUserId String? // Links to User.id from main schema

    // Interview Process Configuration Status
    hasInterviewProcess Boolean @default(false)

    // Relations
    members            CompanyMember[]
    jobs               Job[]
    companyInvitations CompanyInvitation[]
    memberInvitations  MemberInvitation[]
    followers          CompanyFollower[]
    
    // Interview Process Relations (from jobmock.prisma)
    interviewProcesses InterviewProcess[]
    jobMockSessions    JobMockSession[]

    // Subscription & Billing
    subscription       CompanySubscription?
    payments           CompanyPayment[]
    invoices           CompanyInvoice[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([slug])
    @@index([verificationStatus])
    @@index([createdByUserId])
}

// Company Followers (students following companies for job alerts)
model CompanyFollower {
    id        String   @id @default(cuid())
    userId    String
    companyId String
    createdAt DateTime @default(now())

    user    User    @relation("UserFollowedCompanies", fields: [userId], references: [id], onDelete: Cascade)
    company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    @@unique([userId, companyId])
    @@index([userId])
    @@index([companyId])
}

enum CompanyVerificationStatus {
    PENDING
    VERIFIED
    REJECTED
}

// Company Members - connects Users to Companies with roles
// This replaces the old "Recruiter" model with a clearer structure
model CompanyMember {
    id        String @id @default(cuid())
    
    userId    String // Links to User.id from main schema (SSO)
    companyId String

    // Role & Title
    role           CompanyMemberRole     @default(RECRUITER)
    jobTitle       CompanyMemberJobTitle @default(OTHER)
    jobTitleCustom String? // If jobTitle is OTHER, use this

    // Profile info (can differ from User profile)
    displayName String?
    email       String
    phone       String?

    // Permissions (JSON array for flexibility)
    // Default permissions: ["view_jobs", "post_jobs", "view_applications", "review_candidates"]
    // HEAD gets all: ["view_jobs", "post_jobs", "view_applications", "review_candidates", "manage_members", "manage_company", "manage_billing"]
    permissions Json @default("[\"view_jobs\", \"post_jobs\", \"view_applications\", \"review_candidates\"]")

    // Invite tracking
    inviteStatus MemberInviteStatus @default(ACCEPTED) // ACCEPTED if self-registered
    invitedById  String? // CompanyMember ID who invited this user
    invitedAt    DateTime?
    acceptedAt   DateTime?

    // Activity
    isActive     Boolean   @default(true)
    lastActiveAt DateTime?

    // Relations
    user                 User             @relation("UserCompanyMemberships", fields: [userId], references: [id], onDelete: Cascade)
    company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
    postedJobs           Job[]            @relation("PostedBy")
    reviewedApplications JobApplication[] @relation("ReviewedBy")

    // Self-referential for invite tracking
    invitedMembers CompanyMember[] @relation("InvitedBy")
    invitedBy      CompanyMember?  @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

    // Sent invitations
    sentInvitations MemberInvitation[] @relation("SentInvitations")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // A user can only be a member of a company once
    @@unique([userId, companyId])
    @@index([userId])
    @@index([companyId])
    @@index([email])
    @@index([role])
}

enum MemberInviteStatus {
    PENDING
    ACCEPTED
    REVOKED
    EXPIRED
}

// Invitations for new members to join a company
model MemberInvitation {
    id        String  @id @default(cuid())
    companyId String
    email     String
    name      String?

    // Assigned role for when they join
    role     CompanyMemberRole     @default(RECRUITER)
    jobTitle CompanyMemberJobTitle @default(RECRUITER)

    // Invite details
    inviteCode  String             @unique
    invitedById String // CompanyMember who sent the invite
    status      MemberInviteStatus @default(PENDING)
    message     String?            @db.Text // Optional invite message

    // Timestamps
    expiresAt  DateTime?
    acceptedAt DateTime?
    createdAt  DateTime  @default(now())

    // Relations
    company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
    invitedBy CompanyMember @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)

    // After acceptance, link to the created member
    resultingMemberId String?

    @@index([email])
    @@index([inviteCode])
    @@index([status])
    @@index([companyId])
}

// Company invitations for new companies (invite-only system for platform access)
model CompanyInvitation {
    id          String                  @id @default(cuid())
    email       String
    companyName String?
    invitedBy   String? // Platform admin user ID
    inviteCode  String                  @unique
    status      CompanyInvitationStatus @default(PENDING)
    acceptedAt  DateTime?
    expiresAt   DateTime?
    metadata    Json?

    // Used after accepted
    companyId String?
    company   Company? @relation(fields: [companyId], references: [id])

    createdAt DateTime @default(now())

    @@index([email])
    @@index([inviteCode])
    @@index([status])
}

enum CompanyInvitationStatus {
    PENDING
    ACCEPTED
    EXPIRED
    REVOKED
}

// ============================================
// HIRING SUBSCRIPTION & BILLING
// ============================================

enum HiringSubscriptionPlan {
    FREE
    PRO
    ENTERPRISE
}

enum HiringSubscriptionStatus {
    ACTIVE
    CANCELLED
    EXPIRED
    PAST_DUE
    TRIALING
}

enum HiringPaymentStatus {
    PENDING
    PROCESSING
    SUCCEEDED
    FAILED
    REFUNDED
    CANCELLED
}

// Company Subscription for Hiring Platform
model CompanySubscription {
    id        String @id @default(cuid())
    companyId String @unique
    company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    // Plan details
    plan   HiringSubscriptionPlan   @default(FREE)
    status HiringSubscriptionStatus @default(ACTIVE)

    // Dodo Payments IDs
    dodoSubscriptionId String? @unique
    dodoProductId      String?
    dodoPriceId        String?

    // Plan limits
    maxJobPosts        Int @default(3)
    maxApplications    Int @default(50)
    maxInterviewTemplates Int @default(1)
    maxTeamMembers     Int @default(1)

    // Features
    hasAIScreening     Boolean @default(false)
    hasCustomAssignments Boolean @default(false)
    hasPrioritySupport Boolean @default(false)
    hasAPIAccess       Boolean @default(false)
    hasSSO             Boolean @default(false)
    hasWhiteLabel      Boolean @default(false)

    // Billing
    amount       Float   @default(0)
    currency     String  @default("INR")
    billingCycle String  @default("monthly")

    // Period tracking
    currentPeriodStart DateTime  @default(now())
    currentPeriodEnd   DateTime?
    trialStart         DateTime?
    trialEnd           DateTime?
    cancelledAt        DateTime?

    metadata Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    payments CompanyPayment[]

    @@index([companyId])
    @@index([status])
    @@index([dodoSubscriptionId])
}

// Company Payment records
model CompanyPayment {
    id        String @id @default(cuid())
    companyId String
    company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    subscriptionId String?
    subscription   CompanySubscription? @relation(fields: [subscriptionId], references: [id])

    // Dodo Payments IDs
    dodoPaymentId         String? @unique
    dodoCheckoutSessionId String? @unique

    amount   Float
    currency String              @default("INR")
    status   HiringPaymentStatus @default(PENDING)

    paymentMethod String?
    billingEmail  String?
    billingName   String?
    description   String?
    metadata      Json?

    paidAt     DateTime?
    failedAt   DateTime?
    refundedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([companyId])
    @@index([subscriptionId])
    @@index([status])
    @@index([dodoPaymentId])
    @@index([dodoCheckoutSessionId])

    invoice CompanyInvoice?
}

// Invoice Status
enum HiringInvoiceStatus {
    DRAFT
    PENDING
    PAID
    VOID
    UNCOLLECTIBLE
}

// Company Invoice for billing records
model CompanyInvoice {
    id        String @id @default(cuid())
    companyId String
    company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    paymentId String  @unique
    payment   CompanyPayment @relation(fields: [paymentId], references: [id])

    // Invoice details
    invoiceNumber String  @unique
    status        HiringInvoiceStatus @default(DRAFT)
    
    // Line items stored as JSON
    lineItems Json
    
    // Amounts
    subtotal     Float
    taxAmount    Float   @default(0)
    taxRate      Float   @default(0)
    discount     Float   @default(0)
    totalAmount  Float
    
    // Currency
    currency String @default("INR")
    
    // Company billing details at time of invoice
    billingName    String?
    billingEmail   String?
    billingAddress String?
    billingCity    String?
    billingState   String?
    billingCountry String?
    billingPincode String?
    gstNumber      String?
    
    // Dates
    invoiceDate   DateTime @default(now())
    dueDate       DateTime?
    paidAt        DateTime?
    
    // PDF URL (generated invoice PDF)
    pdfUrl String?
    
    // Notes
    notes String?
    
    metadata Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([companyId])
    @@index([status])
    @@index([invoiceNumber])
    @@index([invoiceDate])
}

// ============================================
// INTERVIEW PROCESS TEMPLATES
// Reusable templates for interview processes
// ============================================

enum TemplateStyle {
    STARTUP     // Fast-paced, fewer rounds
    FAANG       // Comprehensive, algorithmic focus
    MNC         // Traditional corporate style
    CUSTOM      // User-generated
}

enum TemplateCategory {
    ENGINEERING
    PRODUCT
    DESIGN
    DATA_SCIENCE
    MARKETING
    SALES
    OPERATIONS
    INTERN
    GENERAL
}

model InterviewProcessTemplate {
    id          String   @id @default(cuid())
    name        String
    description String?  @db.Text
    
    // Template classification
    style       TemplateStyle    @default(CUSTOM)
    category    TemplateCategory @default(GENERAL)
    
    // Template configuration (rounds stored as JSON)
    // Structure: [{ roundType, title, durationMinutes, format, description }]
    rounds      Json
    
    // Metadata
    estimatedDurationWeeks Int?
    roundCount             Int      @default(0)
    
    // AI Generated flag
    isAiGenerated Boolean @default(false)
    aiPrompt      String? @db.Text // The prompt used to generate this template
    
    // Public availability
    isPublic    Boolean  @default(true)
    
    // Usage stats
    usageCount  Int      @default(0)
    
    // Creator info (null for system templates)
    createdByCompanyId String?
    createdByUserId    String?
    
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([style])
    @@index([category])
    @@index([isPublic])
    @@index([usageCount])
}