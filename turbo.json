{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"globalEnv": [
		"NODE_ENV",
		"DATABASE_URL",
		"DIRECT_URL",
		"JWT_SECRET",
		"BETTER_AUTH_URL",
		"BETTER_AUTH_SECRET",
		"GOOGLE_CLIENT_ID",
		"GOOGLE_SECRET_ID",
		"GITHUB_CLIENT_ID",
		"GITHUB_SECRET_ID",
		"RAZORPAY_KEY_SECRET",
		"RESEND_API_KEY",
		"TRUEFOOL_API_KEY",
		"INTER_PLATFORM_SECRET",
		"TRUEFOOL_DOMAIN",
		"WORKER_SECRET",
		"UPSTASH_VECTOR_REST_URL",
		"UPSTASH_VECTOR_REST_TOKEN",
		"R2_ACCOUNT_ID",
		"R2_ACCESS_KEY_ID",
		"R2_SECRET_ACCESS_KEY",
		"R2_BUCKET_NAME",
		"ELEVENLABS_API_KEY",
		"ELEVENLABS_AI_KEY",
		"RESEND_FROM_EMAIL",
		"NEXTAUTH_URL"
	],
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"env": [
				"DATABASE_URL",
				"DIRECT_URL",
				"NODE_ENV",
				"BETTER_AUTH_URL",
				"BETTER_AUTH_SECRET",
				"NEXT_PUBLIC_BASE_URL",
				"GOOGLE_CLIENT_ID",
				"GOOGLE_SECRET_ID",
				"GITHUB_CLIENT_ID",
				"GITHUB_SECRET_ID",
				"RESEND_API_KEY",
				"RAZORPAY_KEY_SECRET",
				"NEXT_PUBLIC_RAZORPAY_KEY_ID",
				"DODO_PAYMENTS_API_KEY",
				"DODO_UNI_STARTER_MONTHLY_ID",
				"DODO_UNI_STARTER_YEARLY_ID",
				"DODO_UNI_GROWTH_MONTHLY_ID",
				"DODO_UNI_GROWTH_YEARLY_ID",
				"DODO_PRO_PRODUCT_ID",
				"S3_ACCESS_KEY",
				"S3_SECRET_KEY",
				"S3_REGION",
				"S3_BUCKET_NAME",
				"R2_ACCOUNT_ID",
				"R2_ACCESS_KEY_ID",
				"R2_SECRET_ACCESS_KEY",
				"R2_BUCKET_NAME",
				"OPENAI_API_KEY",
				"STUDY_PLAN_ASSISTANT_ID",
				"AI_PROJECT_GENERATOR_ASSISTANT_ID",
				"ANTHROPIC_API_KEY",
				"SARVAM_API_KEY",
				"EXA_API_KEY",
				"CLOUDINARY_CLOUD_NAME",
				"CLOUDINARY_API_KEY",
				"CLOUDINARY_API_SECRET",
				"INTER_PLATFORM_SECRET",
				"TRUEFOOL_API_KEY",
				"TRUEFOOL_DOMAIN",
				"ELEVENLABS_API_KEY",
				"NEXT_PUBLIC_ELEVENLABS_AGENT_ID",
				"NEXT_PUBLIC_ELEVENLABS_MOCKVOICE",
				"NEXT_PUBLIC_ELEVENLABS_GENERAL_MOCK",
				"CRON_SECRET",
				"JWT_SECRET",
				"LEARN_PLATFORM_URL",
				"GITHUB_NIRAJ_JHA_TOKEN",
				"WORKER_API_URL",
				"NEXT_PUBLIC_WORKER_URL",
				"WORKER_SECRET",
				"FALAI_API_KEY",
				"G_ANALYTICS_ID",
				"GITHUB_TOKEN",
				"NODE_ENV",
				"JWT_SECRET",
				"NEXT_PUBLIC_BASE_URL",
				"RAZORPAY_KEY_SECRET",
				"UPSTASH_VECTOR_REST_URL",
				"UPSTASH_VECTOR_REST_TOKEN",
				"DODO_PRO_PRODUCT_ID",
				"PATHFINDER_ASSISTANT_ID"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env",
				".env.local",
				".env.production",
				".env.development"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"dist/**"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"env": [
				"DATABASE_URL",
				"DIRECT_URL",
				"NODE_ENV",
				"BETTER_AUTH_URL",
				"BETTER_AUTH_SECRET",
				"NEXT_PUBLIC_BASE_URL",
				"GOOGLE_CLIENT_ID",
				"GOOGLE_SECRET_ID",
				"GITHUB_CLIENT_ID",
				"GITHUB_SECRET_ID",
				"RESEND_API_KEY",
				"RAZORPAY_KEY_SECRET",
				"NEXT_PUBLIC_RAZORPAY_KEY_ID",
				"DODO_PAYMENTS_API_KEY",
				"S3_ACCESS_KEY",
				"S3_SECRET_KEY",
				"S3_REGION",
				"S3_BUCKET_NAME",
				"R2_ACCOUNT_ID",
				"R2_ACCESS_KEY_ID",
				"R2_SECRET_ACCESS_KEY",
				"R2_BUCKET_NAME",
				"OPENAI_API_KEY",
				"STUDY_PLAN_ASSISTANT_ID",
				"AI_PROJECT_GENERATOR_ASSISTANT_ID",
				"ANTHROPIC_API_KEY",
				"SARVAM_API_KEY",
				"EXA_API_KEY",
				"CLOUDINARY_CLOUD_NAME",
				"CLOUDINARY_API_KEY",
				"CLOUDINARY_API_SECRET",
				"INTER_PLATFORM_SECRET",
				"TRUEFOOL_API_KEY",
				"TRUEFOOL_DOMAIN",
				"ELEVENLABS_API_KEY",
				"NEXT_PUBLIC_ELEVENLABS_AGENT_ID",
				"NEXT_PUBLIC_ELEVENLABS_MOCKVOICE",
				"NEXT_PUBLIC_ELEVENLABS_GENERAL_MOCK",
				"CRON_SECRET",
				"JWT_SECRET",
				"LEARN_PLATFORM_URL",
				"GITHUB_NIRAJ_JHA_TOKEN",
				"WORKER_API_URL",
				"NEXT_PUBLIC_WORKER_URL",
				"WORKER_SECRET",
				"FALAI_API_KEY",
				"G_ANALYTICS_ID",
				"UPSTASH_VECTOR_REST_URL",
				"UPSTASH_VECTOR_REST_TOKEN",
				"DODO_PRO_PRODUCT_ID",
				"PATHFINDER_ASSISTANT_ID"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"check-types": {
			"dependsOn": [
				"^check-types"
			]
		}
	}
}