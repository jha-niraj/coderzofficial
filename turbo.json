{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"globalEnv": [
		".env",
		"DATABASE_URL",
		"DIRECT_URL",
		"NODE_ENV",
		"JWT_SECRET",
		"NEXTAUTH_URL",
		"RAZORPAY_KEY_SECRET",
		"RESEND_API_KEY",
		"TRUEFOOL_API_KEY",
		"INTER_PLATFORM_SECRET",
		"TRUEFOOL_DOMAIN",
		"ELEVENLABS_AI_KEY",
		"GITHUB_NIRAJ_JHA_TOKEN",
		"WORKER_SECRET",
		"OPENAI_API_KEY"
	],
	"tasks": {
		"generate": {
			"cache": false,
			"inputs": [
				"prisma/schema.prisma"
			],
			"outputs": [
				"../../node_modules/.prisma/client/**"
			]
		},
		"build": {
			"dependsOn": [
				"^generate",
				"^build"
			],
			"env": [
				"DATABASE_URL",
				"DIRECT_URL",
				"NODE_ENV",
				"JWT_SECRET",
				"NEXTAUTH_URL",
				"RAZORPAY_KEY_SECRET",
				"RESEND_API_KEY",
				"TRUEFOOL_API_KEY",
				"INTER_PLATFORM_SECRET",
				"TRUEFOOL_DOMAIN",
				"ELEVENLABS_AI_KEY",
				"GITHUB_NIRAJ_JHA_TOKEN",
				"WORKER_SECRET",
				"OPENAI_API_KEY"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"check-types": {
			"dependsOn": [
				"^check-types"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}